---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const {
  title = 'Diagnostic IA pour dirigeants de PME | Magnetic-IA',
  description = "La plupart des projets IA échouent. Diagnostic IA, priorisation et feuille de route pour dirigeants de PME — Hauts-de-France.",
  image = 'https://magnetic-ia.fr/images/og-image.png',
  url = 'https://magnetic-ia.fr',
  type = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://magnetic-ia.fr');
---

<!doctype html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO de base -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Indexation -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="David Gacquer — Magnetic-IA" />
    <meta name="keywords" content="diagnostic IA, projet IA PME, feuille de route IA, priorisation IA, consultant IA Lille, consultant IA Hauts-de-France, David Gacquer" />

    <!-- Open Graph (LinkedIn, Facebook) -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Magnetic-IA" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@davidgacquer" />
    <meta name="twitter:creator" content="@davidgacquer" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicon & PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-192.png" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0a0e1a" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />

    <!-- Fonts critiques (Inter + Instrument Serif pour le H1) — non-render-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Fonts critiques : Inter + Instrument Serif chargées en priorité -->
    <link rel="preload" as="style" fetchpriority="high" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <!-- Fonts décoratifs (slider hero desktop seulement) — chargement différé -->
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600&family=JetBrains+Mono:wght@600&display=optional"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Caveat:wght@400;600&family=JetBrains+Mono:wght@600&display=swap" rel="stylesheet" />
    </noscript>

    <meta name="generator" content={Astro.generator} />

    <!-- JSON-LD : WebSite + SearchAction (GEO) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://magnetic-ia.fr/#website",
        "name": "Magnetic-IA",
        "url": "https://magnetic-ia.fr",
        "description": "Diagnostic IA et feuille de route pour dirigeants de TPE et PME — Hauts-de-France",
        "inLanguage": "fr-FR",
        "publisher": { "@id": "https://magnetic-ia.fr/#organization" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://magnetic-ia.fr/blog?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>

    <!-- JSON-LD : Person — entité David Gacquer pour LLMs -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "https://magnetic-ia.fr/#david-gacquer",
        "name": "David Gacquer",
        "url": "https://magnetic-ia.fr",
        "image": "https://magnetic-ia.fr/images/david-gacquer.png",
        "jobTitle": "Expert en diagnostic IA pour PME",
        "description": "David Gacquer aide les dirigeants de TPE et PME à identifier les projets IA les plus utiles avant d'investir. Diagnostic IA, priorisation et feuille de route — basé à Wambrechies dans les Hauts-de-France.",
        "knowsAbout": [
          "Diagnostic IA",
          "Priorisation de projets IA",
          "Feuille de route IA",
          "ROI des projets IA",
          "Intelligence artificielle pour PME",
          "RGPD et IA Act"
        ],
        "hasOccupation": {
          "@type": "Occupation",
          "name": "Consultant en diagnostic IA pour PME",
          "occupationLocation": {
            "@type": "State",
            "name": "Hauts-de-France"
          }
        },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Wambrechies",
          "addressRegion": "Hauts-de-France",
          "postalCode": "59118",
          "addressCountry": "FR"
        },
        "email": "contact@magnetic-ia.fr",
        "telephone": "+33632351294",
        "sameAs": [
          "https://www.linkedin.com/in/david-gacquer-20973064/",
          "https://twitter.com/davidgacquer"
        ],
        "worksFor": {
          "@type": "Organization",
          "name": "Magnetic-IA",
          "url": "https://magnetic-ia.fr"
        }
      }
    </script>

    <!-- JSON-LD : ProfessionalService -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "@id": "https://magnetic-ia.fr/#organization",
        "name": "Magnetic-IA",
        "description": "Diagnostic IA et feuille de route pour dirigeants de TPE et PME — Hauts-de-France",
        "url": "https://magnetic-ia.fr",
        "founder": {
          "@type": "Person",
          "name": "David Gacquer",
          "sameAs": "https://www.linkedin.com/in/david-gacquer-20973064/"
        },
        "areaServed": {
          "@type": "State",
          "name": "Hauts-de-France"
        },
        "serviceType": "Conseil en intelligence artificielle",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "290 rue Saint Exupéry, appt 21",
          "addressLocality": "Wambrechies",
          "postalCode": "59118",
          "addressRegion": "Hauts-de-France",
          "addressCountry": "FR"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "contact@magnetic-ia.fr",
          "telephone": "+33632351294",
          "contactType": "customer service"
        },
        "sameAs": [
          "https://www.linkedin.com/in/david-gacquer-20973064/",
          "https://twitter.com/davidgacquer"
        ]
      }
    </script>

    <!-- Thème au chargement (anti-flash) -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          if (saved === 'light') {
            document.documentElement.classList.remove('dark');
          } else {
            document.documentElement.classList.add('dark');
            if (!saved) localStorage.setItem('theme', 'dark');
          }
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body class="antialiased min-h-screen">

    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KHXNW4C4" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <slot />
    <CookieBanner />

    <!-- Scroll ancres : gestion JS complète pour iOS Safari + Android -->
    <script is:inline>
      (function () {
        var NAV_H = 80;

        function scrollToHash(hash, smooth) {
          if (!hash || hash.length <= 1) return;
          var target = document.querySelector(hash);
          if (!target) return;
          var top = target.getBoundingClientRect().top + window.scrollY - NAV_H;
          window.scrollTo({ top: top, behavior: smooth ? 'smooth' : 'auto' });
        }

        // Hash présent à l'arrivée : on corrige après stabilisation du layout
        // Délai 300ms pour laisser fonts + images se poser sur mobile réel
        if (window.location.hash) {
          window.addEventListener('load', function () {
            setTimeout(function () {
              scrollToHash(window.location.hash, false);
            }, 300);
          });
        }

        // Clics sur ancres : smooth scroll JS seulement si on est déjà sur la bonne page
        document.addEventListener('click', function (e) {
          var link = e.target.closest('a[href*="#"]');
          if (!link) return;
          var href = link.getAttribute('href');
          var hashIdx = href.indexOf('#');
          if (hashIdx === -1) return;
          var hash = href.slice(hashIdx);
          if (hash.length <= 1) return;
          // Extraire le chemin cible (avant le #)
          var targetPath = href.slice(0, hashIdx);
          // Normaliser : "" ou "/" = page d'accueil
          if (targetPath === '') targetPath = window.location.pathname;
          if (targetPath === '/') targetPath = '/';
          var currentPath = window.location.pathname;
          // Si la cible est une autre page, laisser le navigateur gérer
          if (targetPath !== currentPath && !(targetPath === '/' && currentPath === '/')) return;
          // Même page : on intercepte et on scrolle
          e.preventDefault();
          if (typeof window.closeMobileMenu === 'function') window.closeMobileMenu();
          setTimeout(function () { scrollToHash(hash, true); }, 60);
        });
      })();
    </script>

    <!-- Analytics chargés après le rendu de la page -->
    <script is:inline>
      window.addEventListener('load', function () {
        // Google Tag Manager
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-KHXNW4C4');

        // Google Analytics 4
        var ga = document.createElement('script');
        ga.async = true;
        ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-441514514';
        document.head.appendChild(ga);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-441514514');

        // Microsoft Clarity
        (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","x05fn89yxs");
      });
    </script>

    <script is:inline>
      window.toggleTheme = function () {
        var html = document.documentElement;
        if (html.classList.contains('dark')) {
          html.classList.remove('dark');
          try { localStorage.setItem('theme', 'light'); } catch (e) {}
        } else {
          html.classList.add('dark');
          try { localStorage.setItem('theme', 'dark'); } catch (e) {}
        }
      };
    </script>

    <!-- Bouton scroll-to-top -->
    <button id="scrollTopBtn" aria-label="Remonter en haut" style="
      position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 200;
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--accent); color: white; border: none;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem; cursor: pointer;
      box-shadow: 0 4px 16px rgba(96,165,250,0.35);
      opacity: 0; transform: translateY(8px);
      transition: opacity 0.25s ease, transform 0.25s ease;
      pointer-events: none;
    ">↑</button>
    <script is:inline>
      (function () {
        var btn = document.getElementById('scrollTopBtn');
        window.addEventListener('scroll', function () {
          var show = window.scrollY > 400;
          btn.style.opacity = show ? '1' : '0';
          btn.style.transform = show ? 'translateY(0)' : 'translateY(8px)';
          btn.style.pointerEvents = show ? 'auto' : 'none';
        }, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>

    <!-- Animations au scroll — différées pour ne pas bloquer le main thread -->
    <script is:inline>
      (function () {
        function initObserver() {
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
          document.querySelectorAll('.reveal').forEach(function (el) {
            observer.observe(el);
          });
        }
        if ('requestIdleCallback' in window) {
          requestIdleCallback(initObserver, { timeout: 2000 });
        } else {
          window.addEventListener('load', initObserver);
        }
      })();
    </script>
  </body>
</html>
