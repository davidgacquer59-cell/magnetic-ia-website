---
// About V2 — épuré, sans Omotenashi, sans slider
---

<section id="a-propos" class="py-16 md:py-24" style="background: var(--bg-primary);">
  <div class="max-w-4xl mx-auto px-6 lg:px-8">

    <!-- Eyebrow -->
    <div class="inline-flex items-center gap-3 mb-8 reveal">
      <span class="w-6 h-px" style="background: var(--accent);"></span>
      <span class="text-xs font-mono font-semibold uppercase tracking-[0.22em]" style="color: var(--accent);">À propos</span>
    </div>

    <!-- Titre -->
    <h2 class="font-bold tracking-tight leading-tight mb-12 reveal">
      David Gacquer,
      <span class="font-serif italic" style="color: var(--text-tertiary);"> partenaire stratégique.</span>
    </h2>

    <!-- Bio -->
    <div class="flex flex-col md:flex-row gap-10 items-start reveal">

      <img
        src="/images/david-gacquer.png"
        alt="David Gacquer — Fondateur Magnetic-IA"
        class="rounded-2xl object-cover shadow-lg flex-shrink-0 w-full md:w-auto"
        style="width: 180px; height: 220px; object-position: top;"
        loading="lazy"
        decoding="async"
        width="180"
        height="220"
      />

      <div class="space-y-5 text-base leading-relaxed" style="color: var(--text-secondary);">
        <p>
          25 ans à piloter des projets digitaux dans le retail, l'industrie et le e-commerce.
          Aujourd'hui je mets cette expérience au service des dirigeants de TPE et PME qui veulent
          intégrer l'IA <strong style="color: var(--text-primary);">sans tomber dans le piège du gadget technologique.</strong>
        </p>
        <p style="color: var(--text-tertiary);">
          Basé à Wambrechies · Hauts-de-France · à distance
        </p>

        <!-- 3 non-négociables -->
        <div class="pt-4 space-y-3">
          <div class="text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--text-tertiary);">3 non-négociables</div>
          {[
            { num: '01', label: 'Aucun outil imposé', color: '#60a5fa', bg: 'rgba(59,130,246,0.12)', border: 'rgba(59,130,246,0.25)' },
            { num: '02', label: 'Aucune automatisation par défaut', color: '#a78bfa', bg: 'rgba(139,92,246,0.12)', border: 'rgba(139,92,246,0.25)' },
            { num: '03', label: 'Aucune complexité ajoutée', color: '#34d399', bg: 'rgba(16,185,129,0.12)', border: 'rgba(16,185,129,0.25)' },
          ].map(item => (
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-xs font-bold"
                style={`background: ${item.bg}; border: 1px solid ${item.border}; color: ${item.color};`}>
                {item.num}
              </div>
              <span class="font-medium" style="color: var(--text-primary);">{item.label}</span>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>
