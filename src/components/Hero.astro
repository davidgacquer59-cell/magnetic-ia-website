---
// Hero V6 — nouveau positionnement + slider Chaos→Clarté
---

<section class="relative overflow-hidden pt-20 md:pt-24 pb-12 md:pb-16">

  <!-- Fond -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(96,165,250,0.12) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 50% at 50% 0%, transparent 30%, var(--bg-primary) 100%);"></div>
    <div class="absolute top-1/3 -left-32 w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.08), transparent 70%); filter: blur(80px);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="hero-mobile-wrap grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center py-6 md:py-12">

      <!-- ── TEXTE ── -->
      <div class="fade-in-up">

        <!-- Eyebrow -->
        <div class="hero-eyebrow inline-flex items-center gap-3 mb-6 md:mb-8">
          <span class="w-6 h-px" style="background: var(--accent);"></span>
          <span class="text-xs font-mono font-semibold uppercase tracking-[0.1em] md:tracking-[0.22em]" style="color: var(--accent);">Cadrage de projets IA · Hauts-de-France</span>
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--accent);"></span>
        </div>

        <!-- H1 -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.02] mb-7 md:mb-6">
          La plupart des projets IA échouent.<br />
          <span class="font-serif italic" style="color: var(--accent);">Avant même de commencer.</span>
        </h1>

        <!-- Sous-texte -->
        <p class="hero-subtext text-lg leading-relaxed mb-9 md:mb-10 max-w-lg" style="color: var(--text-secondary);">
          Pas à cause de la technologie.<br/>
          <strong style="color: var(--text-primary);">À cause du manque de cadrage en amont.</strong><br/>
          <span class="hidden md:inline">J'aide les dirigeants de PME à poser les bonnes questions avant d'investir dans les mauvais outils.</span>
          <span class="md:hidden">J'aide les dirigeants de PME à éviter les mauvais outils.</span>
        </p>

        <!-- CTAs -->
        <div class="hero-ctas flex flex-wrap gap-4">
          <a href="#diagnostic"
            class="inline-flex items-center gap-2 px-7 py-4 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition shadow-xl shadow-blue-500/25 text-base">
            Faire le diagnostic
            <span class="text-xs font-semibold px-2 py-0.5 rounded" style="background: rgba(255,255,255,0.2);">2 min</span>
            →
          </a>
          <a href="#methode"
            class="inline-flex items-center gap-2 px-7 py-4 font-medium rounded-xl transition text-base"
            style="border: 1px solid var(--border); color: var(--text-primary);">
            Voir la méthode
          </a>
        </div>

      </div>

      <!-- ── SLIDER CHAOS → CLARTÉ ── (caché sur mobile) -->
      <div class="hero-slider-wrap relative w-full fade-in-up" style="animation-delay:0.2s;">
        <div
          id="heroSlider"
          class="demo-slider relative rounded-2xl overflow-hidden w-full"
          style="aspect-ratio: 1/1; background: var(--bg-secondary); border: 1px solid var(--border); box-shadow: 0 4px 32px rgba(0,0,0,0.08); cursor: ew-resize;"
        >
          <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(0,0,0,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.04) 1px, transparent 1px); background-size: 36px 36px;"></div>

          <!-- Labels colonnes APRÈS -->
          <div class="demo-col-labels absolute top-0 left-0 right-0 flex z-10 pointer-events-none" style="padding: 8px 2px 0;">
            <div class="demo-col-label" style="color: #86efac; flex-direction: column; gap: 2px;">
              <span>QUICK WIN</span>
              <span style="font-size: 7px; opacity: 0.6; letter-spacing: 0.05em; text-transform: none; font-family: inherit;">Fort impact · Faible effort</span>
            </div>
            <div class="demo-col-label" style="color: #60a5fa; flex-direction: column; gap: 2px;">
              <span>À PLANIFIER</span>
              <span style="font-size: 7px; opacity: 0.6; letter-spacing: 0.05em; text-transform: none; font-family: inherit;">Fort impact · Fort effort</span>
            </div>
            <div class="demo-col-label" style="color: #fbbf24; flex-direction: column; gap: 2px;">
              <span>À DÉLÉGUER</span>
              <span style="font-size: 7px; opacity: 0.6; letter-spacing: 0.05em; text-transform: none; font-family: inherit;">Faible impact · Faible effort</span>
            </div>
            <div class="demo-col-label" style="color: #fca5a5; flex-direction: column; gap: 2px;">
              <span>À ARRÊTER</span>
              <span style="font-size: 7px; opacity: 0.6; letter-spacing: 0.05em; text-transform: none; font-family: inherit;">Faible impact · Fort effort</span>
            </div>
          </div>
          <div class="demo-col-sep" style="left: 25%;"></div>
          <div class="demo-col-sep" style="left: 50%;"></div>
          <div class="demo-col-sep" style="left: 75%;"></div>

          <!-- Post-its — 16 activités business, chaos → matrice impact/effort -->
          <div class="dpi postit-green"  style="--cx:5%;  --cy:6%;  --cr:-5deg; --sx:2%;  --sy:18%; --sr:-2deg;">Relances clients</div>
          <div class="dpi postit-yellow" style="--cx:62%; --cy:10%; --cr:4deg;  --sx:2%;  --sy:38%; --sr:1deg;">Comptes-rendus</div>
          <div class="dpi postit-green"  style="--cx:30%; --cy:72%; --cr:-3deg; --sx:2%;  --sy:58%; --sr:-1deg;">Qualification leads</div>
          <div class="dpi postit-pink"   style="--cx:74%; --cy:58%; --cr:6deg;  --sx:2%;  --sy:78%; --sr:2deg;">Prise de RDV</div>

          <div class="dpi postit-blue"   style="--cx:18%; --cy:22%; --cr:5deg;  --sx:27%; --sy:18%; --sr:2deg;">Nouveau CRM</div>
          <div class="dpi postit-orange" style="--cx:50%; --cy:30%; --cr:-4deg; --sx:27%; --sy:38%; --sr:-1deg;">Refonte process</div>
          <div class="dpi postit-blue"   style="--cx:82%; --cy:24%; --cr:3deg;  --sx:27%; --sy:58%; --sr:1deg;">Formation équipe</div>
          <div class="dpi postit-orange" style="--cx:40%; --cy:86%; --cr:-6deg; --sx:27%; --sy:78%; --sr:-2deg;">Refonte site</div>

          <div class="dpi postit-yellow" style="--cx:8%;  --cy:48%; --cr:-3deg; --sx:52%; --sy:18%; --sr:-1deg;">Facturation</div>
          <div class="dpi postit-pink"   style="--cx:55%; --cy:52%; --cr:5deg;  --sx:52%; --sy:38%; --sr:2deg;">Reporting</div>
          <div class="dpi postit-yellow" style="--cx:22%; --cy:60%; --cr:-5deg; --sx:52%; --sy:58%; --sr:1deg;">Saisie données</div>
          <div class="dpi postit-pink"   style="--cx:76%; --cy:76%; --cr:4deg;  --sx:52%; --sy:78%; --sr:-1deg;">Administratif</div>

          <div class="dpi postit-orange" style="--cx:36%; --cy:14%; --cr:3deg;  --sx:77%; --sy:18%; --sr:-2deg;">Tester tous les outils IA</div>
          <div class="dpi postit-blue"   style="--cx:68%; --cy:42%; --cr:-4deg; --sx:77%; --sy:38%; --sr:1deg;">Réunions inutiles</div>
          <div class="dpi postit-orange" style="--cx:12%; --cy:80%; --cr:6deg;  --sx:77%; --sy:58%; --sr:-1deg;">Tout faire soi-même</div>
          <div class="dpi postit-blue"   style="--cx:58%; --cy:84%; --cr:-3deg; --sx:77%; --sy:78%; --sr:2deg;">Être partout à la fois</div>

          <!-- Handle -->
          <div id="heroHandleLine" class="demo-handle-line pointer-events-none"></div>
          <div id="heroHandleKnob" class="demo-handle-knob pointer-events-none">⇄</div>

          <!-- Labels bas -->
          <div class="demo-chaos-label absolute bottom-0 left-0 right-0 h-8 flex items-center justify-center pointer-events-none" style="background: linear-gradient(to top, rgba(0,0,0,0.06), transparent); z-index:5;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:0.15em; color:var(--text-tertiary); text-transform:uppercase;">AVANT · DISPERSION</span>
          </div>
          <div class="demo-sorted-label absolute bottom-0 left-0 right-0 h-8 flex items-center justify-center pointer-events-none" style="background: linear-gradient(to top, rgba(5,150,105,0.08), transparent); z-index:5;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:0.15em; color:#059669; text-transform:uppercase;">CADRAGE · DECISION</span>
          </div>
        </div>

        <!-- Range slider -->
        <input type="range" id="heroRange" min="0" max="100" value="20"
          class="w-full mt-3 h-1.5 rounded-full appearance-none cursor-pointer"
          style="background: linear-gradient(to right, var(--accent) 20%, var(--bg-tertiary) 20%);"
        />
        <div class="flex justify-between mt-1 text-xs" style="color: var(--text-tertiary);">
          <span>← Chaos</span><span>Clarté →</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .dpi {
    position: absolute; width: 22%; padding: 0.45rem 0.35rem;
    font-family: 'Caveat', cursive; font-size: 1.05rem; font-weight: 600;
    color: #1a1a1a; text-align: center; line-height: 1.15; border-radius: 3px;
    box-shadow: 0 6px 16px -6px rgba(0,0,0,0.55);
    left: var(--cx); top: var(--cy); transform: rotate(var(--cr));
    transition: left 0.6s cubic-bezier(.2,.7,.2,1), top 0.6s cubic-bezier(.2,.7,.2,1), transform 0.6s cubic-bezier(.2,.7,.2,1);
    z-index: 3; user-select: none;
  }
  .demo-slider.is-sorted .dpi { left: var(--sx); top: var(--sy); transform: rotate(var(--sr)); }
  .demo-handle-line { position: absolute; top: 0; bottom: 0; width: 2px; background: var(--accent); left: 20%; transform: translateX(-50%); z-index: 8; box-shadow: 0 0 8px rgba(96,165,250,0.5); }
  .demo-handle-knob { position: absolute; top: 50%; left: 20%; transform: translate(-50%,-50%); width: 34px; height: 34px; background: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; color: white; font-weight: bold; z-index: 9; box-shadow: 0 4px 14px rgba(96,165,250,0.45); }
  .demo-col-label { flex: 1; text-align: center; font-family: 'JetBrains Mono',monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; opacity: 0; transition: opacity 0.5s ease; display: flex; align-items: center; justify-content: center; }
  .demo-slider.is-sorted .demo-col-label { opacity: 1; }
  .demo-col-sep { position: absolute; top: 28px; bottom: 14px; width: 1px; background: rgba(255,255,255,0.07); opacity: 0; transition: opacity 0.5s ease; z-index: 2; }
  .demo-slider.is-sorted .demo-col-sep { opacity: 1; }
  .demo-chaos-label { transition: opacity 0.4s ease; }
  .demo-sorted-label { opacity: 0; transition: opacity 0.4s ease; }
  .demo-slider.is-sorted .demo-chaos-label { opacity: 0; }
  .demo-slider.is-sorted .demo-sorted-label { opacity: 1; }

  @media (max-width: 767px) {
    /* Hero plein écran sur mobile */
    .hero-mobile-wrap {
      min-height: calc(100svh - 80px);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding-top: 1.5rem;
      padding-bottom: 2rem;
    }
    /* Slider caché sur mobile — apparaît en scrollant */
    .hero-slider-mobile { display: none !important; }
    /* Eyebrow compact */
    .hero-eyebrow { margin-bottom: 1.25rem !important; }
    /* H1 bien dimensionné */
    h1 { font-size: clamp(1.9rem, 7vw, 2.4rem) !important; line-height: 1.12 !important; }
    /* Sous-texte aéré */
    .hero-subtext { font-size: 1rem !important; line-height: 1.7 !important; margin-bottom: 0 !important; }
    /* CTAs en bas */
    .hero-ctas { margin-top: auto; }
  }
  /* Slider affiché uniquement au-dessus de 768px */
  @media (min-width: 768px) {
    .hero-slider-mobile { display: block !important; }
  }
</style>

<script>
  const slider     = document.getElementById('heroSlider')     as HTMLElement | null;
  const range      = document.getElementById('heroRange')      as HTMLInputElement | null;
  const handleLine = document.getElementById('heroHandleLine') as HTMLElement | null;
  const handleKnob = document.getElementById('heroHandleKnob') as HTMLElement | null;

  function updatePos(val: number) {
    const pct = Math.max(0, Math.min(100, val));
    if (handleLine) handleLine.style.left = pct + '%';
    if (handleKnob) handleKnob.style.left = pct + '%';
    if (range) { range.value = String(Math.round(pct)); range.style.background = `linear-gradient(to right, var(--accent) ${pct}%, var(--bg-tertiary) ${pct}%)`; }
    if (slider) slider.classList.toggle('is-sorted', pct > 50);
  }

  range?.addEventListener('input', () => updatePos(Number(range.value)));

  if (slider) {
    let dragging = false;
    const getPct = (clientX: number) => ((clientX - slider.getBoundingClientRect().left) / slider.getBoundingClientRect().width) * 100;
    slider.addEventListener('mousedown', (e) => { dragging = true; updatePos(getPct(e.clientX)); e.preventDefault(); });
    window.addEventListener('mousemove', (e) => { if (dragging) updatePos(getPct(e.clientX)); });
    window.addEventListener('mouseup', () => { dragging = false; });
    slider.addEventListener('touchstart', (e) => { dragging = true; updatePos(getPct(e.touches[0].clientX)); }, { passive: true });
    window.addEventListener('touchmove', (e) => { if (dragging) { e.preventDefault(); updatePos(getPct(e.touches[0].clientX)); } }, { passive: false });
    window.addEventListener('touchend', () => { dragging = false; });
  }
  updatePos(20);
</script>
