---
// Hero V4 — slider interactif post-its mobiles (chaos → colonnes)
---

<section class="relative pt-20 overflow-hidden">

  <!-- Fond : grille de points + halos -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(96,165,250,0.18) 1px, transparent 1px); background-size: 36px 36px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 0%, transparent 40%, var(--bg-primary) 100%);"></div>
    <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to bottom, transparent, var(--bg-primary));"></div>
    <div class="absolute top-1/3 -left-24 w-80 h-80 rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.12), transparent 70%); filter: blur(60px);"></div>
    <div class="absolute top-1/4 right-0 w-72 h-72 rounded-full" style="background: radial-gradient(circle, rgba(139,92,246,0.08), transparent 70%); filter: blur(60px);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-6 pb-10 w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Texte gauche -->
      <div class="fade-in-up">

        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-3 mb-8">
          <span class="w-6 h-px" style="background: var(--accent);"></span>
          <span class="text-xs font-mono font-semibold uppercase tracking-[0.2em]" style="color: var(--accent);">Cadrage de projets IA · Hauts-de-France</span>
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--accent);"></span>
        </div>

        <!-- H1 -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.03]">
          Avant les outils,<br />
          <span class="font-serif italic" style="color: var(--accent);">la réflexion.</span>
        </h1>

        <!-- Sous-titre -->
        <p class="mt-6 text-xl leading-relaxed max-w-lg" style="color: var(--text-secondary);">
          Je cadre vos projets IA pour que vous décidiez avec clarté — pas en empilant des outils.
        </p>

        <!-- Stat BPI -->
        <p class="mt-5 text-sm leading-relaxed" style="color: var(--text-tertiary);">
          <strong style="color: var(--text-secondary);">58% des dirigeants de PME</strong> voient l'IA comme un enjeu de survie. Autant n'ont aucune stratégie. —
          <a href="https://www.francenum.gouv.fr/magazine-du-numerique/lia-dans-les-pme-et-eti-francaises-une-revolution-tranquille" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition underline underline-offset-2">Bpifrance Le Lab, 2025 ↗</a>
        </p>

        <!-- CTAs -->
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition shadow-xl shadow-blue-500/20">
            Faire le point sur mon projet
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
          <a href="#methode" class="inline-flex items-center gap-2 px-6 py-3.5 font-medium rounded-xl transition" style="border: 1px solid var(--border); color: var(--text-primary);">
            Voir la méthode
          </a>
        </div>
      </div>

      <!-- Visuel : slider interactif -->
      <div class="relative max-w-md mx-auto lg:mx-0 lg:ml-auto w-full">

        <div
          id="heroSlider"
          class="hero-slider relative rounded-3xl overflow-hidden"
          style="aspect-ratio: 1/1; background: linear-gradient(135deg, rgba(15,20,36,0.97), rgba(10,14,26,0.92)); border: 1px solid var(--border); cursor: ew-resize;"
        >
          <!-- Grille de fond -->
          <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 36px 36px;"></div>

          <!-- Labels colonnes (visibles en état trié) -->
          <div class="col-labels absolute top-0 left-0 right-0 flex z-10 pointer-events-none" style="padding: 12px 4px 0;">
            <div class="col-label" style="color: #86efac;">GARDER</div>
            <div class="col-label" style="color: #60a5fa;">AMPLIFIER</div>
            <div class="col-label" style="color: #fca5a5;">ARRÊTER</div>
            <div class="col-label" style="color: #c4b5fd;">PARKING</div>
          </div>

          <!-- Séparateurs colonnes -->
          <div class="col-sep" style="left: 25%;"></div>
          <div class="col-sep" style="left: 50%;"></div>
          <div class="col-sep" style="left: 75%;"></div>

          <!-- Post-its — GARDER -->
          <div class="pi postit-yellow" style="--cx:8%;  --cy:22%; --cr:-6deg; --sx:2%;  --sy:26%; --sr:-2deg;">CRM</div>
          <div class="pi postit-pink"   style="--cx:72%; --cy:14%; --cr:4deg;  --sx:2%;  --sy:52%; --sr:1deg;">Newsletter</div>
          <div class="pi postit-yellow" style="--cx:80%; --cy:44%; --cr:-3deg; --sx:2%;  --sy:74%; --sr:-1deg;">SEO local</div>
          <!-- AMPLIFIER -->
          <div class="pi postit-green"  style="--cx:52%; --cy:82%; --cr:-2deg; --sx:27%; --sy:26%; --sr:2deg;">LinkedIn</div>
          <div class="pi postit-pink"   style="--cx:28%; --cy:74%; --cr:7deg;  --sx:27%; --sy:52%; --sr:-1deg;">Facturation</div>
          <div class="pi postit-blue"   style="--cx:26%; --cy:48%; --cr:-5deg; --sx:27%; --sy:74%; --sr:1deg;">Analytics</div>
          <!-- ARRÊTER -->
          <div class="pi postit-orange" style="--cx:38%; --cy:34%; --cr:3deg;  --sx:52%; --sy:26%; --sr:-2deg;">Pub Meta</div>
          <div class="pi postit-orange" style="--cx:4%;  --cy:38%; --cr:-4deg; --sx:52%; --sy:52%; --sr:1deg;">Webinars</div>
          <div class="pi postit-yellow" style="--cx:44%; --cy:10%; --cr:6deg;  --sx:52%; --sy:74%; --sr:-1deg;">Chatbot</div>
          <!-- PARKING -->
          <div class="pi postit-green"  style="--cx:14%; --cy:62%; --cr:5deg;  --sx:77%; --sy:26%; --sr:2deg;">Refonte site</div>
          <div class="pi postit-blue"   style="--cx:62%; --cy:64%; --cr:-8deg; --sx:77%; --sy:52%; --sr:-1deg;">Agent IA</div>
          <div class="pi postit-purple" style="--cx:86%; --cy:68%; --cr:4deg;  --sx:77%; --sy:74%; --sr:1deg;">Notion</div>

          <!-- Handle -->
          <div id="heroHandleLine" class="hero-handle-line pointer-events-none"></div>
          <div id="heroHandleKnob" class="hero-handle-knob pointer-events-none">⇄</div>

          <!-- Labels état -->
          <div class="chaos-label absolute bottom-3 left-0 right-0 text-center pointer-events-none" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em; color: var(--text-tertiary); text-transform: uppercase; z-index: 5;">
            AVANT · DISPERSION
          </div>
          <div class="sorted-label absolute bottom-3 left-0 right-0 text-center pointer-events-none" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em; color: #86efac; text-transform: uppercase; z-index: 5;">
            APRÈS CADRAGE · DÉCISION
          </div>
        </div>

        <!-- Barre range accessible -->
        <input
          type="range"
          id="heroRange"
          min="0" max="100" value="20"
          class="w-full mt-3 h-1.5 rounded-full appearance-none cursor-pointer"
          style="background: linear-gradient(to right, var(--accent) 20%, var(--bg-tertiary) 20%);"
        />
        <div class="flex justify-between mt-1 text-xs" style="color: var(--text-tertiary);">
          <span>Chaos</span>
          <span>Clarté</span>
        </div>
      </div>

    </div>

    <!-- Stats barre -->
    <div class="mt-12 grid grid-cols-2 lg:grid-cols-4 gap-8 pt-8 border-t" style="border-color: var(--border);">
      <div class="fade-in-up" style="animation-delay: 0.1s;">
        <div class="text-4xl font-bold" style="color: var(--text-primary);">25 ans</div>
        <div class="mt-1 text-sm" style="color: var(--text-tertiary);">Marketing, digital, e-commerce</div>
      </div>
      <div class="fade-in-up" style="animation-delay: 0.2s;">
        <div class="text-4xl font-bold" style="color: var(--text-primary);">+20</div>
        <div class="mt-1 text-sm" style="color: var(--text-tertiary);">Projets digitaux pilotés</div>
      </div>
      <div class="fade-in-up" style="animation-delay: 0.3s;">
        <div class="text-4xl font-bold" style="color: var(--text-primary);">+35 %</div>
        <div class="mt-1 text-sm" style="color: var(--text-tertiary);">Ventes générées en 3 mois</div>
      </div>
      <div class="fade-in-up" style="animation-delay: 0.4s;">
        <div class="text-4xl font-bold" style="color: var(--text-primary);">3 mois</div>
        <div class="mt-1 text-sm" style="color: var(--text-tertiary);">Pour voir les premiers résultats</div>
      </div>
    </div>
  </div>
</section>

<style>
  .pi {
    position: absolute;
    width: 22%;
    padding: 0.45rem 0.35rem;
    font-family: 'Caveat', cursive;
    font-size: 1.05rem;
    font-weight: 600;
    color: #1a1a1a;
    text-align: center;
    line-height: 1.15;
    border-radius: 3px;
    box-shadow: 0 6px 16px -6px rgba(0,0,0,0.55);
    left: var(--cx);
    top: var(--cy);
    transform: rotate(var(--cr));
    transition:
      left   0.6s cubic-bezier(.2,.7,.2,1),
      top    0.6s cubic-bezier(.2,.7,.2,1),
      transform 0.6s cubic-bezier(.2,.7,.2,1);
    z-index: 3;
    user-select: none;
  }
  .hero-slider.is-sorted .pi {
    left: var(--sx);
    top: var(--sy);
    transform: rotate(var(--sr));
  }

  .hero-handle-line {
    position: absolute;
    top: 0; bottom: 0;
    width: 2px;
    background: var(--accent);
    left: 20%;
    transform: translateX(-50%);
    z-index: 8;
    box-shadow: 0 0 8px rgba(96,165,250,0.5);
  }
  .hero-handle-knob {
    position: absolute;
    top: 50%;
    left: 20%;
    transform: translate(-50%, -50%);
    width: 34px; height: 34px;
    background: var(--accent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; color: white; font-weight: bold;
    z-index: 9;
    box-shadow: 0 4px 14px rgba(96,165,250,0.45);
  }

  .col-label {
    flex: 1;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .hero-slider.is-sorted .col-label { opacity: 1; }

  .col-sep {
    position: absolute;
    top: 28px; bottom: 14px;
    width: 1px;
    background: rgba(255,255,255,0.07);
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: 2;
    pointer-events: none;
  }
  .hero-slider.is-sorted .col-sep { opacity: 1; }

  .chaos-label  { transition: opacity 0.4s ease; }
  .sorted-label { opacity: 0; transition: opacity 0.4s ease; }
  .hero-slider.is-sorted .chaos-label  { opacity: 0; }
  .hero-slider.is-sorted .sorted-label { opacity: 1; }
</style>

<script>
  const slider    = document.getElementById('heroSlider')    as HTMLElement | null;
  const range     = document.getElementById('heroRange')     as HTMLInputElement | null;
  const handleLine = document.getElementById('heroHandleLine') as HTMLElement | null;
  const handleKnob = document.getElementById('heroHandleKnob') as HTMLElement | null;

  function updatePos(val: number) {
    const pct = Math.max(0, Math.min(100, val));
    if (handleLine) handleLine.style.left = pct + '%';
    if (handleKnob) handleKnob.style.left = pct + '%';
    if (range) {
      range.value = String(Math.round(pct));
      range.style.background = `linear-gradient(to right, var(--accent) ${pct}%, var(--bg-tertiary) ${pct}%)`;
    }
    if (slider) {
      slider.classList.toggle('is-sorted', pct > 50);
    }
  }

  if (range) {
    range.addEventListener('input', () => updatePos(Number(range.value)));
  }

  if (slider) {
    let dragging = false;
    const getPct = (clientX: number) => {
      const r = slider.getBoundingClientRect();
      return ((clientX - r.left) / r.width) * 100;
    };
    slider.addEventListener('mousedown', (e) => {
      dragging = true;
      updatePos(getPct(e.clientX));
      e.preventDefault();
    });
    window.addEventListener('mousemove', (e) => { if (dragging) updatePos(getPct(e.clientX)); });
    window.addEventListener('mouseup',   () => { dragging = false; });
    slider.addEventListener('touchstart', (e) => {
      dragging = true;
      updatePos(getPct(e.touches[0].clientX));
    }, { passive: true });
    window.addEventListener('touchmove', (e) => {
      if (dragging) { e.preventDefault(); updatePos(getPct(e.touches[0].clientX)); }
    }, { passive: false });
    window.addEventListener('touchend', () => { dragging = false; });
  }

  updatePos(20);
</script>
