---
// Hero V5 — alignement propre, carousel schémas soigné
---

<section class="relative overflow-hidden pt-20 pb-8 md:pb-12">

  <!-- Fond -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(96,165,250,0.15) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 50% at 50% 0%, transparent 30%, var(--bg-primary) 100%);"></div>
    <div class="absolute bottom-0 left-0 right-0 h-40" style="background: linear-gradient(to bottom, transparent, var(--bg-primary));"></div>
    <div class="absolute top-1/3 -left-32 w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.1), transparent 70%); filter: blur(80px);"></div>
    <div class="absolute top-1/4 -right-16 w-96 h-96 rounded-full" style="background: radial-gradient(circle, rgba(139,92,246,0.07), transparent 70%); filter: blur(80px);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1fr_640px] gap-8 lg:gap-10 items-center w-full py-8 md:py-12">

      <!-- ── TEXTE ── -->
      <div class="fade-in-up">

        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-3 mb-10">
          <span class="w-6 h-px" style="background: var(--accent);"></span>
          <span class="text-xs font-mono font-semibold uppercase tracking-[0.22em]" style="color: var(--accent);">Cadrage de projets IA · Hauts-de-France</span>
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--accent);"></span>
        </div>

        <!-- H1 -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.02] mb-7">
          Avant les outils,<br />
          <span class="font-serif italic" style="color: var(--accent);">la réflexion.</span>
        </h1>

        <!-- Phrase signature -->
        <p class="text-xl leading-relaxed mb-10 max-w-lg" style="color: var(--text-secondary);">
          Beaucoup d'entreprises cherchent les bons outils.<br/>
          <strong style="color: var(--text-primary);">Les meilleures commencent par les bonnes questions.</strong>
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a href="#contact"
            class="inline-flex items-center gap-2 px-7 py-4 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition shadow-xl shadow-blue-500/25 text-base">
            Faire le point sur mon projet
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a href="#methode"
            class="inline-flex items-center gap-2 px-7 py-4 font-medium rounded-xl transition text-base"
            style="border: 1px solid var(--border); color: var(--text-primary);">
            Voir la méthode
          </a>
        </div>

      </div>

      <!-- ── VISUEL POST-ITS CHAOS ── -->
      <div class="relative w-full fade-in-up" style="animation-delay:0.2s;">
        <div class="relative rounded-2xl overflow-hidden w-full"
          style="aspect-ratio: 4/3; background: #080d1a; border: 1px solid rgba(96,165,250,0.18); box-shadow: 0 0 60px -20px rgba(96,165,250,0.2); padding: 1rem;">

          <!-- Grille fond tableau -->
          <div class="absolute inset-0" style="
            background-image:
              linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
              linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 44px 44px;
          "></div>

          <!-- Post-its flottants — répartition organique sur tout l'espace -->
          <div class="postit postit-yellow float-anim" style="top:4%;  left:5%;   --rot:-8deg; transform:rotate(-8deg);  animation-delay:0s;    font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Trop d'emails</div>
          <div class="postit postit-blue   float-anim" style="top:6%;  left:43%;  --rot:5deg;  transform:rotate(5deg);   animation-delay:1.3s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Cash flow ?</div>
          <div class="postit postit-pink   float-anim" style="top:3%;  right:5%;  --rot:-4deg; transform:rotate(-4deg);  animation-delay:0.7s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Recruter ?</div>
          <div class="postit postit-green  float-anim" style="top:20%; left:16%;  --rot:3deg;  transform:rotate(3deg);   animation-delay:1.8s;  font-size:clamp(0.6rem,1.1vw,0.9rem);  min-width:85px; padding:0.9rem 0.75rem;">Mon équipe me sollicite</div>
          <div class="postit postit-purple float-anim" style="top:24%; right:6%;  --rot:7deg;  transform:rotate(7deg);   animation-delay:0.5s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">CRM ?</div>
          <div class="postit postit-orange float-anim" style="top:36%; left:5%;   --rot:4deg;  transform:rotate(4deg);   animation-delay:0.4s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Trop d'appels</div>
          <div class="postit postit-green  float-anim" style="top:38%; left:40%;  --rot:-5deg; transform:rotate(-5deg);  animation-delay:1.1s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">IA ?</div>
          <div class="postit postit-pink   float-anim" style="top:48%; left:6%;   --rot:-6deg; transform:rotate(-6deg);  animation-delay:1s;    font-size:clamp(0.6rem,1.1vw,0.9rem);  min-width:85px; padding:0.9rem 0.75rem;">Je manque de temps</div>
          <div class="postit postit-yellow float-anim" style="top:52%; right:5%;  --rot:-4deg; transform:rotate(-4deg);  animation-delay:0.3s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Priorités ?</div>
          <div class="postit postit-blue   float-anim" style="top:64%; left:20%;  --rot:6deg;  transform:rotate(6deg);   animation-delay:0.9s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Devis en attente</div>
          <div class="postit postit-orange float-anim" style="top:67%; right:7%;  --rot:-6deg; transform:rotate(-6deg);  animation-delay:1.5s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Processus ?</div>
          <div class="postit postit-purple float-anim" style="top:78%; left:5%;   --rot:-7deg; transform:rotate(-7deg);  animation-delay:0.2s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Relances clients</div>
          <div class="postit postit-pink   float-anim" style="top:80%; left:42%;  --rot:4deg;  transform:rotate(4deg);   animation-delay:1.6s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Reporting ?</div>
          <div class="postit postit-green  float-anim" style="top:14%; right:8%;  --rot:-5deg; transform:rotate(-5deg);  animation-delay:2.1s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Formation équipe</div>
          <div class="postit postit-yellow float-anim" style="top:30%; left:44%;  --rot:6deg;  transform:rotate(6deg);   animation-delay:2.3s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Marges ?</div>
          <div class="postit postit-orange float-anim" style="top:57%; left:36%;  --rot:-3deg; transform:rotate(-3deg);  animation-delay:2s;    font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Site web ?</div>
          <div class="postit postit-blue   float-anim" style="top:72%; right:6%;  --rot:5deg;  transform:rotate(5deg);   animation-delay:1.9s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Réunions inutiles</div>
          <div class="postit postit-purple float-anim" style="top:86%; left:26%;  --rot:-4deg; transform:rotate(-4deg);  animation-delay:2.4s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Croissance ?</div>
          <div class="postit postit-pink   float-anim" style="top:88%; right:8%;  --rot:6deg;  transform:rotate(6deg);   animation-delay:0.6s;  font-size:clamp(0.65rem,1.2vw,0.95rem); min-width:85px; padding:0.9rem 0.75rem;">Facturation ?</div>

          <!-- Label bas -->
          <div class="absolute bottom-0 left-0 right-0 h-10 flex items-center justify-center"
            style="background: linear-gradient(to top, rgba(8,13,26,0.95), transparent);">
            <span style="font-family:'Courier New',monospace; font-size:9px; letter-spacing:0.18em; color:rgba(255,255,255,0.35); text-transform:uppercase;">
              Votre situation actuelle · Dispersion
            </span>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

