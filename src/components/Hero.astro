---
// Hero V5 — alignement propre, carousel schémas soigné
---

<section class="relative overflow-hidden pt-20">

  <!-- Fond -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(96,165,250,0.15) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 50% at 50% 0%, transparent 30%, var(--bg-primary) 100%);"></div>
    <div class="absolute bottom-0 left-0 right-0 h-40" style="background: linear-gradient(to bottom, transparent, var(--bg-primary));"></div>
    <div class="absolute top-1/3 -left-32 w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.1), transparent 70%); filter: blur(80px);"></div>
    <div class="absolute top-1/4 -right-16 w-96 h-96 rounded-full" style="background: radial-gradient(circle, rgba(139,92,246,0.07), transparent 70%); filter: blur(80px);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1fr_480px] gap-16 items-center w-full py-10 pb-6">

      <!-- ── TEXTE ── -->
      <div class="fade-in-up">

        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-3 mb-10">
          <span class="w-6 h-px" style="background: var(--accent);"></span>
          <span class="text-xs font-mono font-semibold uppercase tracking-[0.22em]" style="color: var(--accent);">Cadrage de projets IA · Hauts-de-France</span>
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--accent);"></span>
        </div>

        <!-- H1 -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.02] mb-7">
          Avant les outils,<br />
          <span class="font-serif italic" style="color: var(--accent);">la réflexion.</span>
        </h1>

        <!-- Phrase signature -->
        <p class="text-xl leading-relaxed mb-10 max-w-lg" style="color: var(--text-secondary);">
          Beaucoup d'entreprises cherchent les bons outils.<br/>
          <strong style="color: var(--text-primary);">Les meilleures commencent par les bonnes questions.</strong>
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a href="#contact"
            class="inline-flex items-center gap-2 px-7 py-4 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition shadow-xl shadow-blue-500/25 text-base">
            Faire le point sur mon projet
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a href="#methode"
            class="inline-flex items-center gap-2 px-7 py-4 font-medium rounded-xl transition text-base"
            style="border: 1px solid var(--border); color: var(--text-primary);">
            Voir la méthode
          </a>
        </div>

      </div>

      <!-- ── CAROUSEL SCHÉMAS ── -->
      <div class="relative w-full">

        <!-- Container principal -->
        <div id="schemaCarousel"
          class="relative rounded-2xl overflow-hidden w-full"
          style="aspect-ratio: 4/3; background: linear-gradient(135deg, #080d1a 0%, #0c1426 100%); border: 1px solid rgba(96,165,250,0.2); box-shadow: 0 0 60px -20px rgba(96,165,250,0.2);">

          <!-- Halo interne -->
          <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(96,165,250,0.08), transparent 70%);"></div>

          <!-- Slides -->
          {[
            { src: '/images/schemas/du chaos à la clarté.png',           label: 'Du chaos à la clarté' },
            { src: '/images/schemas/02_solution_rarement_probleme.png',  label: 'La solution est rarement le problème' },
            { src: '/images/schemas/03_enquete_diagnostic.png',          label: 'Enquête & diagnostic' },
            { src: '/images/schemas/04_entonnoir_magnetic_ia.png',       label: "L'entonnoir Magnetic-IA" },
            { src: '/images/schemas/06_methode_magnetic_ia.png',         label: 'La méthode en 5 étapes' },
          ].map((slide, i) => (
            <div class="schema-slide absolute inset-0 flex items-center justify-center p-6 transition-opacity duration-700"
              style={i === 0 ? 'opacity:1; z-index:2;' : 'opacity:0; z-index:1;'}>
              <img src={slide.src} alt={slide.label}
                class="w-full h-full object-contain"
                loading={i === 0 ? 'eager' : 'lazy'} />
              <!-- Overlay bas avec label -->
              <div class="absolute bottom-0 left-0 right-0 h-14 flex items-end justify-between px-5 pb-3"
                style="background: linear-gradient(to top, rgba(8,13,26,0.9), transparent);">
                <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.16em; color:rgba(255,255,255,0.5); text-transform:uppercase;">{slide.label}</span>
                <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:rgba(96,165,250,0.5);">{String(i+1).padStart(2,'0')} / 05</span>
              </div>
            </div>
          ))}

          <!-- Dots navigation (en bas) -->
          <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-2 z-10">
            {[0,1,2,3,4].map(i => (
              <button class="schema-dot h-1 rounded-full transition-all duration-300 cursor-pointer"
                style={i === 0 ? 'background:var(--accent); width:1.5rem;' : 'background:rgba(255,255,255,0.2); width:0.375rem;'}
                data-dot={i}></button>
            ))}
          </div>

        </div>

        <!-- Flèches de navigation -->
        <div class="flex justify-end gap-2 mt-3">
          <button id="schemaPrev" class="w-9 h-9 rounded-lg flex items-center justify-center transition hover:opacity-80"
            style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-secondary);">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="schemaNext" class="w-9 h-9 rounded-lg flex items-center justify-center transition hover:opacity-80"
            style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-secondary);">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>

      </div>

    </div>
  </div>
</section>

<script>
  const slides  = document.querySelectorAll<HTMLElement>('.schema-slide');
  const dots    = document.querySelectorAll<HTMLElement>('.schema-dot');
  const prev    = document.getElementById('schemaPrev');
  const next    = document.getElementById('schemaNext');
  const total   = slides.length;
  let current   = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(i: number) {
    slides[current].style.opacity = '0';
    slides[current].style.zIndex  = '1';
    dots[current].style.background = 'rgba(255,255,255,0.2)';
    dots[current].style.width = '0.375rem';
    current = (i + total) % total;
    slides[current].style.opacity = '1';
    slides[current].style.zIndex  = '2';
    dots[current].style.background = 'var(--accent)';
    dots[current].style.width = '1.5rem';
  }

  function startTimer() { timer = setInterval(() => goTo(current + 1), 4000); }
  function stopTimer()  { clearInterval(timer); }

  startTimer();

  document.getElementById('schemaCarousel')?.addEventListener('mouseenter', stopTimer);
  document.getElementById('schemaCarousel')?.addEventListener('mouseleave', startTimer);
  prev?.addEventListener('click', () => { stopTimer(); goTo(current - 1); startTimer(); });
  next?.addEventListener('click', () => { stopTimer(); goTo(current + 1); startTimer(); });
  dots.forEach((d, i) => d.addEventListener('click', () => { stopTimer(); goTo(i); startTimer(); }));
</script>
