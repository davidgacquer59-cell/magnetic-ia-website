---
// Hero V3 — vidéo de fond + proposition claire + animations
---

<section class="relative min-h-screen flex items-center pt-20 overflow-hidden" style="align-items: flex-start;">

  <!-- Canvas particules animées -->
  <canvas id="hero-canvas" class="absolute inset-0 w-full h-full z-0" style="opacity: 0.45;"></canvas>
  <!-- Overlay dégradé pour la lisibilité -->
  <div class="absolute inset-0 z-0" style="background: linear-gradient(135deg, var(--bg-primary) 0%, transparent 50%, var(--bg-primary) 100%);"></div>

  <!-- Halo bleu gauche -->
  <div class="absolute top-1/4 -left-32 w-[500px] h-[500px] rounded-full pointer-events-none z-0" style="background: radial-gradient(circle, rgba(59,130,246,0.15), transparent 70%); filter: blur(60px);"></div>
  <!-- Halo violet droit -->
  <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] rounded-full pointer-events-none z-0" style="background: radial-gradient(circle, rgba(139,92,246,0.1), transparent 70%); filter: blur(60px);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-8 pb-16 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Texte -->
      <div class="fade-in-up">

        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-3 mb-8">
          <span class="w-6 h-px" style="background: var(--accent);"></span>
          <span class="text-xs font-mono font-semibold uppercase tracking-[0.2em]" style="color: var(--accent);">Consultant cadrage IA · Hauts-de-France</span>
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--accent);"></span>
        </div>

        <!-- H1 -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.03]">
          Avant les outils,<br />
          <span class="font-serif italic" style="color: var(--accent);">la réflexion.</span>
        </h1>

        <!-- Sous-titre clair -->
        <p class="mt-6 text-xl leading-relaxed max-w-xl" style="color: var(--text-secondary);">
          Je cadre vos projets IA avant de les lancer : on identifie ce qui crée vraiment de la valeur, on priorise, et on construit un plan d'action concret. <strong style="color: var(--text-primary);">Décider, pas empiler.</strong>
        </p>

        <!-- 3 preuves rapides -->
        <div class="mt-8 flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2); color: var(--accent);">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            25 ans d'expertise
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2); color: var(--accent);">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Aucun outil imposé
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2); color: var(--accent);">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            ROI mesurable
          </span>
        </div>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition shadow-xl shadow-blue-500/20">
            Faire le point sur mon projet IA
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a href="#methode" class="inline-flex items-center gap-2 px-6 py-3.5 font-medium rounded-xl transition" style="border: 1px solid var(--border); color: var(--text-primary);">
            Voir la méthode
          </a>
        </div>
      </div>

      <!-- Visuel post-its (identique v2 — chaos visuel) -->
      <div class="relative aspect-square max-w-md mx-auto lg:mx-0 lg:ml-auto w-full">

        <!-- Cadre avec grille légère -->
        <div class="absolute inset-0 rounded-3xl" style="background: linear-gradient(135deg, rgba(15,20,36,0.9), rgba(10,14,26,0.7)); border: 1px solid var(--border); overflow: hidden;">
          <!-- Grille de fond style v2 -->
          <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 36px 36px;"></div>
        </div>

        <!-- Post-its flottants -->
        <div class="postit postit-yellow float-anim" style="top: 8%;  left: 12%; --rot: -8deg; transform: rotate(-8deg); animation-delay: 0s;">CRM ?</div>
        <div class="postit postit-pink   float-anim" style="top: 6%;  right: 8%; --rot: 6deg;  transform: rotate(6deg);  animation-delay: 1s;">Newsletter</div>
        <div class="postit postit-orange float-anim" style="top: 32%; left: 8%; --rot: 3deg;  transform: rotate(3deg);  animation-delay: 0.5s;">Pub Méta</div>
        <div class="postit postit-yellow float-anim" style="top: 36%; right: 14%; --rot: -5deg; transform: rotate(-5deg); animation-delay: 1.5s;">SEO local</div>
        <div class="postit postit-green  float-anim" style="top: 56%; left: 20%; --rot: -3deg; transform: rotate(-3deg); animation-delay: 2s;">Refonte site</div>
        <div class="postit postit-blue   float-anim" style="top: 58%; right: 6%; --rot: 7deg;  transform: rotate(7deg);  animation-delay: 0.7s;">Agent IA ?</div>
        <div class="postit postit-purple float-anim" style="top: 78%; left: 10%; --rot: 4deg;  transform: rotate(4deg);  animation-delay: 1.2s;">Auto facturation</div>
        <div class="postit postit-pink   float-anim" style="top: 80%; right: 18%; --rot: -6deg; transform: rotate(-6deg); animation-delay: 1.8s;">LinkedIn</div>

        <!-- Label bas -->
        <div class="absolute -bottom-8 left-0 right-0 text-center text-xs uppercase tracking-[0.2em] font-medium" style="color: var(--text-tertiary);">
          Votre situation actuelle · Dispersion
        </div>
      </div>
    </div>

    <!-- Stats barre -->
    <div class="mt-28 lg:mt-36 grid grid-cols-2 lg:grid-cols-4 gap-8 pt-10 border-t" style="border-color: var(--border);">
      <div class="fade-in-up" style="animation-delay: 0.1s;">
        <div class="text-4xl font-bold" style="color: var(--text-primary);">25 ans</div>
        <div class="mt-1 text-sm" style="color: var(--text-tertiary);">Marketing, digital, e-commerce</div>
      </div>
      <div class="fade-in-up" style="animation-delay: 0.2s;">
        <div class="text-4xl font-bold" style="color: var(--text-primary);">+35 %</div>
        <div class="mt-1 text-sm" style="color: var(--text-tertiary);">Ventes e-commerce en 3 mois</div>
      </div>
      <div class="fade-in-up" style="animation-delay: 0.3s;">
        <div class="text-4xl font-bold" style="color: var(--text-primary);">÷ 2</div>
        <div class="mt-1 text-sm" style="color: var(--text-tertiary);">Coût d'acquisition client</div>
      </div>
      <div class="fade-in-up" style="animation-delay: 0.4s;">
        <div class="text-4xl font-bold" style="color: var(--text-primary);">600 k€</div>
        <div class="mt-1 text-sm" style="color: var(--text-tertiary);">Budget acquisition piloté / an</div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  var canvas = document.getElementById('hero-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W, H, particles, animId;

  var PARTICLE_COUNT = 80;
  var MAX_DIST = 140;
  var SPEED = 0.4;
  // Couleur accent bleue alignée sur la charte
  var COLOR = '96, 165, 250';

  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }

  function rand(min, max) { return Math.random() * (max - min) + min; }

  function init() {
    resize();
    particles = [];
    for (var i = 0; i < PARTICLE_COUNT; i++) {
      particles.push({
        x: rand(0, W), y: rand(0, H),
        vx: rand(-SPEED, SPEED), vy: rand(-SPEED, SPEED),
        r: rand(1.5, 3),
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Lignes de connexion
    for (var i = 0; i < particles.length; i++) {
      for (var j = i + 1; j < particles.length; j++) {
        var dx = particles[i].x - particles[j].x;
        var dy = particles[i].y - particles[j].y;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MAX_DIST) {
          ctx.beginPath();
          ctx.strokeStyle = 'rgba(' + COLOR + ',' + (1 - dist / MAX_DIST) * 0.18 + ')';
          ctx.lineWidth = 0.8;
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }

    // Points
    particles.forEach(function (p) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + COLOR + ', 0.6)';
      ctx.fill();

      // Mouvement + rebond
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < 0 || p.x > W) p.vx *= -1;
      if (p.y < 0 || p.y > H) p.vy *= -1;
    });

    animId = requestAnimationFrame(draw);
  }

  window.addEventListener('resize', function () {
    cancelAnimationFrame(animId);
    init();
    draw();
  });

  init();
  draw();
})();
</script>
