---
import Logo from './Logo.astro';
const CALENDLY_URL = 'https://calendly.com/davidgacquer59/consultation-decouverte?utm_source=site&utm_medium=nav&utm_campaign=30min-offert';
---

<nav
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl border-b"
  style="background: color-mix(in srgb, var(--bg-primary) 80%, transparent); border-color: var(--border);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8 h-20 flex items-center justify-between">

    <!-- Logo -->
    <a href="#" class="flex items-center" style="color: var(--text-primary);" aria-label="Magnetic-IA — Accueil">
      <Logo height="42px" />
    </a>

    <!-- Desktop nav — 3 items + CTA -->
    <div class="hidden md:flex items-center gap-8 text-sm font-medium" style="color: var(--text-secondary);">
      <a href="#methode"   class="hover:opacity-100 transition" style="opacity: 0.8;">Méthode</a>
      <a href="#services"  class="hover:opacity-100 transition" style="opacity: 0.8;">Offres</a>
      <a href="#a-propos"  class="hover:opacity-100 transition" style="opacity: 0.8;">À propos</a>
    </div>

    <!-- CTA desktop -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href={CALENDLY_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold rounded-xl hover:opacity-90 transition shadow-lg"
        style="background: var(--text-primary); color: var(--bg-primary);"
      >
        Échanger 30 min →
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      type="button"
      id="mobile-menu-btn"
      class="flex md:hidden w-9 h-9 rounded-full items-center justify-center hover:bg-white/5 transition"
      style="border: 1px solid var(--border); color: var(--text-primary);"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t px-6 py-6 space-y-4"
    style="background: var(--bg-primary); border-color: var(--border);"
  >
    <a href="#methode"  class="block py-2 text-sm font-medium" style="color: var(--text-secondary);" onclick="closeMobileMenu()">Méthode</a>
    <a href="#services" class="block py-2 text-sm font-medium" style="color: var(--text-secondary);" onclick="closeMobileMenu()">Offres</a>
    <a href="#a-propos" class="block py-2 text-sm font-medium" style="color: var(--text-secondary);" onclick="closeMobileMenu()">À propos</a>
    <div class="pt-4 border-t" style="border-color: var(--border);">
      <a
        href={CALENDLY_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-blue-500 text-white text-sm font-semibold rounded-xl hover:bg-blue-600 transition"
      >
        Échanger 30 min →
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var hamburger = document.getElementById('hamburger-icon');
    var closeIco = document.getElementById('close-icon');
    if (btn) {
      btn.addEventListener('click', function () {
        var open = menu.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        hamburger.classList.toggle('hidden');
        closeIco.classList.toggle('hidden');
      });
    }
    window.closeMobileMenu = function () {
      if (menu) menu.classList.add('hidden');
      if (btn) btn.setAttribute('aria-expanded', 'false');
      if (hamburger) hamburger.classList.remove('hidden');
      if (closeIco) closeIco.classList.add('hidden');
    };
  })();
</script>
