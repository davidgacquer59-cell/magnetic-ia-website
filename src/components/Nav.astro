---
import Logo from './Logo.astro';
const CALENDLY_URL = 'https://calendly.com/davidgacquer59/consultation-decouverte?utm_source=site&utm_medium=nav&utm_campaign=30min-offert';
---

<!-- Wrapper fixe pleine largeur — la nav flottante est centrée dedans -->
<div class="floating-nav-wrapper fixed top-0 left-0 right-0 z-50 flex justify-center px-6 lg:px-8 pt-3 pointer-events-none">

  <nav class="floating-nav pointer-events-auto w-full flex flex-col" style="max-width: 1280px;">

    <!-- Barre principale -->
    <div class="h-16 px-5 flex items-center justify-between gap-4">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0" style="color: var(--text-primary);" aria-label="Magnetic-IA — Accueil">
        <Logo height="36px" />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1 text-sm font-medium" style="color: var(--text-secondary);">
        <a href="/#methode"    class="nav-link">Méthode</a>
        <a href="/#services"   class="nav-link">Offres</a>
        <a href="/#diagnostic" class="nav-link">Diagnostic</a>
        <a href="/#a-propos"   class="nav-link">À propos</a>
        <a href="/blog"        class="nav-link">Blog</a>
        <a href="/contact"     class="nav-link">Contact</a>
      </div>

      <!-- CTA + toggle desktop -->
      <div class="hidden lg:flex items-center gap-2.5 flex-shrink-0">
        <button
          type="button"
          onclick="window.toggleTheme()"
          class="theme-toggle w-8 h-8 rounded-full flex items-center justify-center hover:bg-white/5 transition"
          style="border: 1px solid var(--border);"
          aria-label="Basculer thème clair/sombre"
        >
          <svg class="sun-icon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--text-primary);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <svg class="moon-icon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--text-primary);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-xl hover:opacity-90 transition shadow-lg"
          style="background: var(--text-primary); color: var(--bg-primary);"
        >
          Échanger 30 min →
        </a>
      </div>

      <!-- Mobile : toggle + hamburger -->
      <div class="flex lg:hidden items-center gap-2">
        <button
          type="button"
          onclick="window.toggleTheme()"
          class="theme-toggle w-8 h-8 rounded-full flex items-center justify-center hover:bg-white/5 transition"
          style="border: 1px solid var(--border);"
          aria-label="Basculer thème"
        >
          <svg class="sun-icon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--text-primary);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <svg class="moon-icon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--text-primary);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>
        <button
          type="button"
          id="mobile-menu-btn"
          class="w-8 h-8 rounded-full flex items-center justify-center hover:bg-white/5 transition"
          style="border: 1px solid var(--border); color: var(--text-primary);"
          aria-label="Menu"
          aria-expanded="false"
        >
          <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu déroulant (dans la même bulle arrondie) -->
    <div
      id="mobile-menu"
      class="hidden border-t px-5 py-5 space-y-3"
      style="border-color: var(--border);"
    >
      <a href="/#methode"    class="nav-link block" onclick="closeMobileMenu()">Méthode</a>
      <a href="/#services"   class="nav-link block" onclick="closeMobileMenu()">Offres</a>
      <a href="/#diagnostic" class="nav-link block" onclick="closeMobileMenu()">Diagnostic</a>
      <a href="/#a-propos"   class="nav-link block" onclick="closeMobileMenu()">À propos</a>
      <a href="/blog"        class="nav-link block" onclick="closeMobileMenu()">Blog</a>
      <a href="/contact"     class="nav-link block" onclick="closeMobileMenu()">Contact</a>
      <div class="pt-3 border-t" style="border-color: var(--border);">
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-blue-500 text-white text-sm font-semibold rounded-xl hover:bg-blue-600 transition"
        >
          Échanger 30 min →
        </a>
      </div>
    </div>

  </nav>
</div>

<script is:inline>
  (function () {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var hamburger = document.getElementById('hamburger-icon');
    var closeIco = document.getElementById('close-icon');

    if (btn) {
      btn.addEventListener('click', function () {
        var open = menu.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        hamburger.classList.toggle('hidden');
        closeIco.classList.toggle('hidden');
      });
    }

    window.closeMobileMenu = function () {
      if (menu) menu.classList.add('hidden');
      if (btn) btn.setAttribute('aria-expanded', 'false');
      if (hamburger) hamburger.classList.remove('hidden');
      if (closeIco) closeIco.classList.add('hidden');
    };
  })();
</script>
