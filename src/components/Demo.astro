---
// Demo — Slider chaos → clarté, section dédiée
---

<section class="py-16" style="background: var(--bg-primary);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Mission gauche -->
      <div class="reveal">
        <div class="p-6 rounded-2xl" style="background: rgba(96,165,250,0.05); border: 1px solid rgba(96,165,250,0.15);">
          <p class="text-lg font-serif italic leading-relaxed mb-3" style="color: var(--text-primary);">
            "Je remets de la clarté, de la priorité et du ROI dans votre stratégie IA."
          </p>
          <p class="text-sm font-semibold" style="color: var(--accent);">David Gacquer · Magnetic-IA</p>
        </div>
      </div>

      <!-- Slider droite -->
      <div class="reveal reveal-right">
      <div
        id="demoSlider"
        class="demo-slider relative rounded-3xl overflow-hidden"
        style="aspect-ratio: 1/1; background: linear-gradient(135deg, rgba(15,20,36,0.97), rgba(10,14,26,0.92)); border: 1px solid var(--border); cursor: ew-resize; touch-action: none;"
      >
        <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 36px 36px;"></div>

        <div class="demo-col-labels absolute top-0 left-0 right-0 flex z-10 pointer-events-none" style="padding: 12px 4px 0;">
          <div class="demo-col-label" style="color: #86efac;">GARDER</div>
          <div class="demo-col-label" style="color: #60a5fa;">AMPLIFIER</div>
          <div class="demo-col-label" style="color: #fca5a5;">ARRÊTER</div>
          <div class="demo-col-label" style="color: #c4b5fd;">PARKING</div>
        </div>
        <div class="demo-col-sep" style="left: 25%;"></div>
        <div class="demo-col-sep" style="left: 50%;"></div>
        <div class="demo-col-sep" style="left: 75%;"></div>

        <div class="dpi postit-yellow" style="--cx:8%;  --cy:22%; --cr:-6deg; --sx:2%;  --sy:26%; --sr:-2deg;">CRM</div>
        <div class="dpi postit-pink"   style="--cx:72%; --cy:14%; --cr:4deg;  --sx:2%;  --sy:52%; --sr:1deg;">Newsletter</div>
        <div class="dpi postit-yellow" style="--cx:80%; --cy:44%; --cr:-3deg; --sx:2%;  --sy:74%; --sr:-1deg;">SEO local</div>
        <div class="dpi postit-green"  style="--cx:52%; --cy:82%; --cr:-2deg; --sx:27%; --sy:26%; --sr:2deg;">LinkedIn</div>
        <div class="dpi postit-pink"   style="--cx:28%; --cy:74%; --cr:7deg;  --sx:27%; --sy:52%; --sr:-1deg;">Facturation</div>
        <div class="dpi postit-blue"   style="--cx:26%; --cy:48%; --cr:-5deg; --sx:27%; --sy:74%; --sr:1deg;">Analytics</div>
        <div class="dpi postit-orange" style="--cx:38%; --cy:34%; --cr:3deg;  --sx:52%; --sy:26%; --sr:-2deg;">Pub Meta</div>
        <div class="dpi postit-orange" style="--cx:4%;  --cy:38%; --cr:-4deg; --sx:52%; --sy:52%; --sr:1deg;">Webinars</div>
        <div class="dpi postit-yellow" style="--cx:44%; --cy:10%; --cr:6deg;  --sx:52%; --sy:74%; --sr:-1deg;">Chatbot</div>
        <div class="dpi postit-green"  style="--cx:14%; --cy:62%; --cr:5deg;  --sx:77%; --sy:26%; --sr:2deg;">Refonte site</div>
        <div class="dpi postit-blue"   style="--cx:62%; --cy:64%; --cr:-8deg; --sx:77%; --sy:52%; --sr:-1deg;">Agent IA</div>
        <div class="dpi postit-purple" style="--cx:86%; --cy:68%; --cr:4deg;  --sx:77%; --sy:74%; --sr:1deg;">Notion</div>

        <div id="demoHandleLine" class="demo-handle-line pointer-events-none"></div>
        <div id="demoHandleKnob" class="demo-handle-knob pointer-events-none">⇄</div>

        <div class="demo-chaos-label absolute bottom-3 left-0 right-0 text-center pointer-events-none" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em; color: var(--text-tertiary); text-transform: uppercase; z-index: 5;">AVANT · DISPERSION</div>
        <div class="demo-sorted-label absolute bottom-3 left-0 right-0 text-center pointer-events-none" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em; color: #86efac; text-transform: uppercase; z-index: 5;">APRÈS CADRAGE · DÉCISION</div>
      </div>

      <input type="range" id="demoRange" min="0" max="100" value="20"
        class="w-full mt-3 h-1.5 rounded-full appearance-none cursor-pointer"
        style="background: linear-gradient(to right, var(--accent) 20%, var(--bg-tertiary) 20%);"
      />
      <div class="flex justify-between mt-1 text-xs" style="color: var(--text-tertiary);">
        <span>Chaos</span>
        <span>Clarté</span>
      </div>
      </div><!-- fin slider droite -->

    </div><!-- fin grid -->

  </div>
</section>

<style>
  .dpi {
    position: absolute;
    width: 22%;
    padding: 0.45rem 0.35rem;
    font-family: 'Caveat', cursive;
    font-size: 1.05rem;
    font-weight: 600;
    color: #1a1a1a;
    text-align: center;
    line-height: 1.15;
    border-radius: 3px;
    box-shadow: 0 6px 16px -6px rgba(0,0,0,0.55);
    left: var(--cx);
    top: var(--cy);
    transform: rotate(var(--cr));
    transition: left 0.6s cubic-bezier(.2,.7,.2,1), top 0.6s cubic-bezier(.2,.7,.2,1), transform 0.6s cubic-bezier(.2,.7,.2,1);
    z-index: 3;
    user-select: none;
    pointer-events: none;
  }
  .demo-slider.is-sorted .dpi {
    left: var(--sx);
    top: var(--sy);
    transform: rotate(var(--sr));
  }
  .demo-handle-line {
    position: absolute; top: 0; bottom: 0; width: 2px;
    background: var(--accent); left: 20%; transform: translateX(-50%);
    z-index: 8; box-shadow: 0 0 8px rgba(96,165,250,0.5);
  }
  .demo-handle-knob {
    position: absolute; top: 50%; left: 20%;
    transform: translate(-50%, -50%);
    width: 34px; height: 34px;
    background: var(--accent); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; color: white; font-weight: bold;
    z-index: 9; box-shadow: 0 4px 14px rgba(96,165,250,0.45);
  }
  .demo-col-label {
    flex: 1; text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600;
    opacity: 0; transition: opacity 0.5s ease;
  }
  .demo-slider.is-sorted .demo-col-label { opacity: 1; }
  .demo-col-sep {
    position: absolute; top: 28px; bottom: 14px; width: 1px;
    background: rgba(255,255,255,0.07); opacity: 0; transition: opacity 0.5s ease; z-index: 2;
  }
  .demo-slider.is-sorted .demo-col-sep { opacity: 1; }
  .demo-chaos-label  { transition: opacity 0.4s ease; }
  .demo-sorted-label { opacity: 0; transition: opacity 0.4s ease; }
  .demo-slider.is-sorted .demo-chaos-label  { opacity: 0; }
  .demo-slider.is-sorted .demo-sorted-label { opacity: 1; }
</style>

<script>
  const slider     = document.getElementById('demoSlider')     as HTMLElement | null;
  const range      = document.getElementById('demoRange')      as HTMLInputElement | null;
  const handleLine = document.getElementById('demoHandleLine') as HTMLElement | null;
  const handleKnob = document.getElementById('demoHandleKnob') as HTMLElement | null;

  function updatePos(val: number) {
    const pct = Math.max(0, Math.min(100, val));
    if (handleLine) handleLine.style.left = pct + '%';
    if (handleKnob) handleKnob.style.left = pct + '%';
    if (range) {
      range.value = String(Math.round(pct));
      range.style.background = `linear-gradient(to right, var(--accent) ${pct}%, var(--bg-tertiary) ${pct}%)`;
    }
    if (slider) slider.classList.toggle('is-sorted', pct > 50);
  }

  range?.addEventListener('input', () => updatePos(Number(range.value)));

  if (slider) {
    const getPct = (clientX: number) => ((clientX - slider.getBoundingClientRect().left) / slider.getBoundingClientRect().width) * 100;
    slider.addEventListener('pointerdown', (e) => {
      slider.setPointerCapture(e.pointerId);
      updatePos(getPct(e.clientX));
    });
    slider.addEventListener('pointermove', (e) => {
      if (e.buttons > 0) updatePos(getPct(e.clientX));
    });
  }

  updatePos(20);
</script>
