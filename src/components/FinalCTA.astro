---
// FinalCTA V5 — sans email affiché
---

<section id="finalcta" class="py-16 md:py-24 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/3 w-96 h-96 rounded-full opacity-15 blur-3xl" style="background: radial-gradient(circle, var(--accent), transparent);"></div>
    <div class="absolute bottom-0 right-1/3 w-80 h-80 rounded-full opacity-10 blur-3xl" style="background: radial-gradient(circle, #A78BFA, transparent);"></div>
  </div>

  <div class="relative max-w-3xl mx-auto px-6 lg:px-8 text-center reveal">

    <div class="text-sm font-mono font-semibold uppercase tracking-[0.2em] mb-6" style="color: var(--accent);">Passons à l'action</div>

    <h2 class="text-3xl md:text-4xl font-bold tracking-tight leading-tight mb-6">
      Votre projet IA mérite <span class="font-serif italic" style="color: var(--accent);">un vrai cadrage.</span>
    </h2>

    <p class="text-lg leading-relaxed mb-10 max-w-xl mx-auto" style="color: var(--text-secondary);">
      30 minutes offertes pour faire le point sur votre situation, identifier les vrais leviers et voir si on peut travailler ensemble.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
      <a
        href="https://calendly.com/davidgacquer59/consultation-decouverte?utm_source=site&utm_medium=final-cta&utm_campaign=30min-offert"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition shadow-xl shadow-blue-500/25 text-base"
      >
        Réserver mon créneau gratuit →
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-medium transition text-base"
        style="border: 1px solid var(--border); color: var(--text-primary);"
      >
        M'écrire un message
      </a>
    </div>

    <!-- Contacts discrets — sans email -->
    <div class="flex flex-wrap items-center justify-center gap-6 text-sm" style="color: var(--text-tertiary);">
      <a href="https://www.linkedin.com/in/david-gacquer-20973064/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 hover:opacity-80 transition">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <span style="color: var(--border);">·</span>
      <a href="https://wa.me/33632351294" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 hover:opacity-80 transition">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    </div>

  </div>
</section>
