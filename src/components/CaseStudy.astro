---
// CaseStudy V4 — version allégée, 2 cartes côte à côte
---

<section id="cas-client" class="py-16 md:py-24" style="background: var(--bg-secondary);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="mb-12 reveal">
      <div class="text-sm font-semibold uppercase tracking-[0.2em] mb-3" style="color: var(--accent);">Cas clients</div>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight leading-tight">
        Des résultats mesurés,
        <span class="font-serif italic" style="color: var(--text-tertiary);">pas des promesses.</span>
      </h2>
    </div>

    <!-- Stats preuves -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-14 reveal">
      <div class="p-5 rounded-2xl text-center" style="background: var(--bg-primary); border: 1px solid var(--border);">
        <div class="text-3xl font-bold mb-1" style="color: var(--accent);">+20</div>
        <div class="text-xs" style="color: var(--text-tertiary);">Projets digitaux pilotés</div>
      </div>
      <div class="p-5 rounded-2xl text-center" style="background: var(--bg-primary); border: 1px solid var(--border);">
        <div class="text-3xl font-bold mb-1" style="color: #10b981;">+35 %</div>
        <div class="text-xs" style="color: var(--text-tertiary);">Ventes générées en 3 mois</div>
      </div>
      <div class="p-5 rounded-2xl text-center" style="background: var(--bg-primary); border: 1px solid var(--border);">
        <div class="text-3xl font-bold mb-1" style="color: #10b981;">÷ 2</div>
        <div class="text-xs" style="color: var(--text-tertiary);">Coût d'acquisition client</div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

      <!-- Cas 1 : Alfaprint -->
      <div class="rounded-2xl overflow-hidden reveal reveal-left reveal-delay-1" style="border: 1px solid var(--border);">
        <!-- Header coloré léger -->
        <div class="px-6 py-4 flex items-center justify-between" style="background: rgba(59,130,246,0.08); border-bottom: 1px solid rgba(59,130,246,0.15);">
          <div>
            <div class="text-xs font-semibold uppercase tracking-[0.15em] mb-0.5" style="color: #60a5fa;">E-commerce B2B</div>
            <div class="font-bold" style="color: var(--text-primary);">Alfaprint.fr</div>
          </div>
          <div class="text-xs" style="color: var(--text-tertiary);">10 mois · 2024–2025</div>
        </div>

        <!-- KPIs compacts -->
        <div class="grid grid-cols-2 sm:grid-cols-4 divide-x" style="border-bottom: 1px solid var(--border); divide-color: var(--border);">
          {[
            { v: '+35 %', l: 'Ventes' },
            { v: '÷ 2',   l: 'CAC' },
            { v: '+20 %', l: 'Conversion' },
            { v: '+35 %', l: 'Clics' },
          ].map(k => (
            <div class="px-3 py-4 text-center">
              <div class="text-xl font-bold" style="color: #60a5fa;">{k.v}</div>
              <div class="text-xs mt-0.5" style="color: var(--text-tertiary);">{k.l}</div>
            </div>
          ))}
        </div>

        <!-- Citation + avatar -->
        <div class="p-6">
          <blockquote class="font-serif italic leading-relaxed mb-4 text-sm" style="color: var(--text-secondary);">
            « David a remis de l'ordre dans une stratégie qui partait dans tous les sens. En trois mois, on avait des KPI fiables et un ROI publicitaire qu'on n'avait jamais atteint. »
          </blockquote>
          <div class="flex items-center gap-3">
            <img src="/images/abdelkarim-feddal.webp" alt="Abdelkarim Feddal" class="w-9 h-9 rounded-full object-cover flex-shrink-0" />
            <div>
              <div class="font-semibold text-sm" style="color: var(--text-primary);">Abdelkarim Feddal</div>
              <a href="https://www.alfaprint.fr" target="_blank" rel="noopener" class="text-xs hover:opacity-100 transition underline underline-offset-2" style="color: var(--text-tertiary);">Dirigeant — alfaprint.fr ↗</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Cas 2 : SwissLife -->
      <div class="rounded-2xl overflow-hidden reveal reveal-right reveal-delay-2" style="border: 1px solid var(--border);">
        <div class="px-6 py-4 flex items-center justify-between" style="background: rgba(139,92,246,0.08); border-bottom: 1px solid rgba(139,92,246,0.15);">
          <div>
            <div class="text-xs font-semibold uppercase tracking-[0.15em] mb-0.5" style="color: #a78bfa;">LinkedIn B2B</div>
            <div class="font-bold" style="color: var(--text-primary);">SwissLife Wambrechies</div>
          </div>
          <div class="text-xs" style="color: var(--text-tertiary);">LinkedIn B2B · 2024</div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 divide-x" style="border-bottom: 1px solid var(--border); divide-color: var(--border);">
          {[
            { v: '+40 %', l: 'Engagement' },
            { v: '5–10',  l: 'Leads/mois' },
            { v: '100 %', l: 'Régularité' },
            { v: '2 mois', l: 'Résultats' },
          ].map(k => (
            <div class="px-3 py-4 text-center">
              <div class="text-xl font-bold" style="color: #a78bfa;">{k.v}</div>
              <div class="text-xs mt-0.5" style="color: var(--text-tertiary);">{k.l}</div>
            </div>
          ))}
        </div>

        <div class="p-6">
          <blockquote class="font-serif italic leading-relaxed mb-4 text-sm" style="color: var(--text-secondary);">
            « Grâce à David, j'ai enfin compris comment structurer ma communication sur LinkedIn. Résultat : j'ai gagné en visibilité et en crédibilité auprès de ma cible. »
          </blockquote>
          <div class="flex items-center gap-3">
            <img src="/images/charlotte-baert.webp" alt="Charlotte Baert" class="w-9 h-9 rounded-full object-cover flex-shrink-0" />
            <div>
              <div class="font-semibold text-sm" style="color: var(--text-primary);">Charlotte Baert</div>
              <a href="https://www.linkedin.com/in/charlotte-baert-swisslife/" target="_blank" rel="noopener" class="text-xs hover:opacity-100 transition underline underline-offset-2" style="color: var(--text-tertiary);">Experte assurance — Agence SwissLife Wambrechies ↗</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
