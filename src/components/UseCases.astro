---

<section id="cas-usage" class="py-24" style="background: var(--bg-secondary);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="max-w-3xl mb-16">
      <div class="text-sm font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--accent);">Cas d'usage concrets</div>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight leading-tight">
        L'IA dans votre quotidien,<br />
        <span class="font-serif italic" style="color: var(--text-tertiary);">avec vos outils existants.</span>
      </h2>
      <p class="mt-6 text-lg leading-relaxed" style="color: var(--text-secondary);">
        Pas de théorie. Des workflows réels, construits sur ce que vous utilisez déjà.
      </p>
    </div>

    <div class="space-y-6">
      {cases.map((c) => (
        <div class="rounded-3xl overflow-hidden" style="border: 1px solid var(--border); background: var(--bg-primary);">
          <div class="grid lg:grid-cols-[260px_1fr_220px]">

            <!-- Gauche : secteur + problème -->
            <div class="p-7 border-b lg:border-b-0 lg:border-r" style="border-color: var(--border);">
              <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wider mb-4" style={`background: ${c.colorSoft}; border: 1px solid ${c.colorBorder}; color: ${c.color};`}>
                {c.sector}
              </div>
              <p class="font-bold text-base mb-5 leading-snug" style="color: var(--text-primary);">{c.title}</p>
              <div class="space-y-2.5">
                {c.problems.map((p) => (
                  <div class="flex items-start gap-2 text-sm" style="color: var(--text-secondary);">
                    <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" style="color: #f87171;">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                    {p}
                  </div>
                ))}
              </div>
            </div>

            <!-- Centre : workflow avec logos -->
            <div class="p-7 border-b lg:border-b-0 lg:border-r" style="border-color: var(--border);">
              <div class="text-xs font-semibold uppercase tracking-[0.15em] mb-6" style={`color: ${c.color};`}>
                La résolution IA
              </div>
              <!-- Workflow : centré verticalement, espacement uniforme -->
              <div class="flex items-center justify-center gap-2 flex-wrap">
                {c.steps.map((step, i) => (
                  <>
                    <!-- Outil -->
                    <div class="flex flex-col items-center text-center" style="width: 72px;">
                      <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-2 overflow-hidden" style={`background: ${c.colorSoft}; border: 1px solid ${c.colorBorder};`}>
                        <div class="w-9 h-9" set:html={logos[step.logo]} />
                      </div>
                      <div class="text-xs font-semibold leading-tight" style="color: var(--text-primary);">{step.name}</div>
                      <div class="text-xs leading-tight mt-0.5" style={`color: var(--text-tertiary); max-width: 72px;`}>{step.desc}</div>
                    </div>
                    <!-- Flèche entre les étapes -->
                    {i < c.steps.length - 1 && (
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--text-tertiary);">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    )}
                  </>
                ))}
              </div>
            </div>

            <!-- Droite : KPI -->
            <div class="p-7">
              <div class="text-xs font-semibold uppercase tracking-[0.15em] mb-5" style="color: var(--text-tertiary);">KPI & résultats</div>
              <div class="space-y-5">
                {c.kpis.map((kpi) => (
                  <div>
                    <div class="text-2xl font-bold" style={`color: ${c.color};`}>{kpi.value}</div>
                    <div class="text-xs mt-0.5" style="color: var(--text-secondary);">{kpi.label}</div>
                  </div>
                ))}
              </div>
            </div>

          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-sm text-center" style="color: var(--text-tertiary);">
      Ces workflows sont construits à partir de vos outils existants. Aucune solution imposée, aucun budget logiciel superflu.
    </p>

  </div>
</section>
