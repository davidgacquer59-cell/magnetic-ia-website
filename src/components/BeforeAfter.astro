---
// BeforeAfter V4 — slider comparaison, post-its réels
---

<section class="py-16 md:py-24" style="background: var(--bg-secondary);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- En-tête -->
    <div class="max-w-3xl mb-10">
      <div class="inline-flex items-center gap-3 mb-4">
        <span class="w-6 h-px" style="background: var(--accent);"></span>
        <span class="text-xs font-mono font-semibold uppercase tracking-[0.2em]" style="color: var(--accent);">Démo · 2 secondes</span>
      </div>
      <h2 class="font-bold tracking-tight leading-tight">
        Glissez le curseur.
        <span class="font-serif italic" style="color: var(--text-tertiary);"> C'est exactement ce que je fais.</span>
      </h2>
      <p class="mt-4 text-lg" style="color: var(--text-secondary);">
        À gauche, votre quotidien. À droite, après cadrage : les mêmes sujets, mais hiérarchisés, séquencés, pilotables.
      </p>
    </div>

    <!-- Slider -->
    <div
      class="compare-container max-w-5xl mx-auto"
      id="compareContainer"
      style="aspect-ratio: 16/9; background: #060c1a; border: 1px solid var(--border);"
    >

      <!-- ══ AVANT ══ -->
      <div class="compare-side before" style="overflow: hidden;">

        <!-- Grille fond tableau -->
        <div class="absolute inset-0" style="
          background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
          background-size: 48px 48px;
        "></div>

        <!-- Post-its chaos -->
        <div class="postit postit-yellow"  style="top:8%;  left:5%;   transform:rotate(-8deg);  font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">Trop d'emails</div>
        <div class="postit postit-pink"    style="top:6%;  left:34%;  transform:rotate(5deg);   font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">Trop d'appels</div>
        <div class="postit postit-orange"  style="top:10%; right:7%;  transform:rotate(-4deg);  font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">Recruter ?</div>
        <div class="postit postit-purple"  style="top:36%; left:6%;   transform:rotate(7deg);   font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">Je manque de temps</div>
        <div class="postit postit-green"   style="top:33%; left:40%;  transform:rotate(-3deg);  font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">IA ?</div>
        <div class="postit postit-blue"    style="top:38%; right:5%;  transform:rotate(6deg);   font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">CRM ?</div>
        <div class="postit postit-pink"    style="top:64%; left:9%;   transform:rotate(-5deg);  font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">Mon équipe me sollicite</div>
        <div class="postit postit-yellow"  style="top:65%; left:40%;  transform:rotate(4deg);   font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">Processus ?</div>
        <div class="postit postit-orange"  style="top:62%; right:8%;  transform:rotate(-6deg);  font-size:clamp(0.6rem,1.3vw,1rem); min-width:70px; padding:0.75rem 0.6rem;">Priorités ?</div>

        <!-- Flèches désordonnées -->
        <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 800 450" preserveAspectRatio="xMidYMid meet">
          <defs>
            <marker id="arrB" markerWidth="5" markerHeight="5" refX="2.5" refY="2.5" orient="auto">
              <path d="M0,0 L5,2.5 L0,5 Z" fill="rgba(96,165,250,0.35)"/>
            </marker>
          </defs>
          <path d="M180 180 Q280 110 360 195" stroke="rgba(96,165,250,0.3)" stroke-width="1.5" fill="none" marker-end="url(#arrB)" stroke-dasharray="5 4"/>
          <path d="M510 200 Q430 280 330 305" stroke="rgba(96,165,250,0.25)" stroke-width="1.5" fill="none" marker-end="url(#arrB)" stroke-dasharray="5 4"/>
          <path d="M630 195 Q590 275 530 305" stroke="rgba(96,165,250,0.25)" stroke-width="1.5" fill="none" marker-end="url(#arrB)" stroke-dasharray="5 4"/>
          <path d="M130 305 Q255 245 375 325" stroke="rgba(96,165,250,0.2)"  stroke-width="1.5" fill="none" marker-end="url(#arrB)" stroke-dasharray="5 4"/>
          <path d="M405 120 Q505 175 455 255" stroke="rgba(96,165,250,0.2)"  stroke-width="1.5" fill="none" marker-end="url(#arrB)" stroke-dasharray="5 4"/>
        </svg>

        <div class="compare-label left">Avant · Dispersion</div>
      </div>

      <!-- ══ APRÈS ══ -->
      <div class="compare-side after" style="background: #060c1a; overflow: hidden;">

        <!-- Grille fond tableau -->
        <div class="absolute inset-0" style="
          background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
          background-size: 48px 48px;
        "></div>

        <!-- SVG : structure cadrage -->
        <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 800 450" preserveAspectRatio="xMidYMid meet">
          <defs>
            <marker id="arrA" markerWidth="5" markerHeight="5" refX="2.5" refY="2.5" orient="auto">
              <path d="M0,0 L5,2.5 L0,5 Z" fill="rgba(96,165,250,0.7)"/>
            </marker>
            <marker id="arrG" markerWidth="5" markerHeight="5" refX="2.5" refY="2.5" orient="auto">
              <path d="M0,0 L5,2.5 L0,5 Z" fill="rgba(134,239,172,0.7)"/>
            </marker>
            <marker id="arrY" markerWidth="5" markerHeight="5" refX="2.5" refY="2.5" orient="auto">
              <path d="M0,0 L5,2.5 L0,5 Z" fill="rgba(252,211,77,0.7)"/>
            </marker>
          </defs>

          <!-- Box CADRAGE -->
          <rect x="300" y="55" width="200" height="40" rx="6" fill="rgba(96,165,250,0.1)" stroke="rgba(96,165,250,0.55)" stroke-width="1.5"/>
          <text x="400" y="80" text-anchor="middle" font-family="Caveat, cursive" font-size="20" font-weight="700" fill="rgba(96,165,250,0.9)" letter-spacing="2">CADRAGE</text>

          <!-- Flèche centrale vers le bas -->
          <path d="M400 95 L400 155" stroke="rgba(96,165,250,0.6)" stroke-width="1.5" fill="none" marker-end="url(#arrA)"/>

          <!-- Vers 3 colonnes -->
          <path d="M400 195 L400 210 L140 210 L140 222" stroke="rgba(134,239,172,0.55)" stroke-width="1.5" fill="none" marker-end="url(#arrG)"/>
          <path d="M400 195 L400 222" stroke="rgba(252,211,77,0.55)" stroke-width="1.5" fill="none" marker-end="url(#arrY)"/>
          <path d="M400 195 L400 210 L660 210 L660 222" stroke="rgba(96,165,250,0.55)" stroke-width="1.5" fill="none" marker-end="url(#arrA)"/>

          <!-- Résultats -->
          <path d="M400 382 L400 408" stroke="rgba(96,165,250,0.45)" stroke-width="1.5" fill="none" marker-end="url(#arrA)"/>
          <rect x="265" y="408" width="270" height="28" rx="5" fill="rgba(96,165,250,0.12)" stroke="rgba(96,165,250,0.45)" stroke-width="1.5"/>
          <text x="400" y="427" text-anchor="middle" font-family="Caveat, cursive" font-size="16" font-weight="700" fill="rgba(96,165,250,0.85)" letter-spacing="1">RÉSULTATS MESURABLES</text>
        </svg>

        <!-- Colonne 1 : Urgent -->
        <div class="absolute" style="left:4%; top:50%; transform:translateY(-50%); width:26%;">
          <div style="border:1.5px solid rgba(134,239,172,0.45); border-radius:10px; padding:clamp(0.4rem,1vw,0.7rem); background:rgba(134,239,172,0.05);">
            <div style="font-family:'Caveat',cursive; font-size:clamp(0.6rem,1.3vw,0.85rem); font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:rgba(134,239,172,0.85); margin-bottom:0.4rem; text-align:center;">Cette semaine</div>
            <div class="org-postit postit-green" style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">Trop d'emails</div>
            <div class="org-postit postit-green" style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">Processus</div>
            <div class="org-postit postit-pink"  style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">Temps équipe</div>
          </div>
        </div>

        <!-- Colonne 2 : Q3 -->
        <div class="absolute" style="left:50%; top:50%; transform:translate(-50%,-50%); width:26%;">
          <div style="border:1.5px solid rgba(252,211,77,0.45); border-radius:10px; padding:clamp(0.4rem,1vw,0.7rem); background:rgba(252,211,77,0.05);">
            <div style="font-family:'Caveat',cursive; font-size:clamp(0.6rem,1.3vw,0.85rem); font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:rgba(252,211,77,0.85); margin-bottom:0.4rem; text-align:center;">Ce trimestre</div>
            <div class="org-postit postit-yellow" style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">CRM</div>
            <div class="org-postit postit-yellow" style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">Recruter</div>
            <div class="org-postit postit-orange" style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">Priorités</div>
          </div>
        </div>

        <!-- Colonne 3 : Long terme -->
        <div class="absolute" style="right:4%; top:50%; transform:translateY(-50%); width:26%;">
          <div style="border:1.5px solid rgba(147,197,253,0.45); border-radius:10px; padding:clamp(0.4rem,1vw,0.7rem); background:rgba(147,197,253,0.05);">
            <div style="font-family:'Caveat',cursive; font-size:clamp(0.6rem,1.3vw,0.85rem); font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:rgba(147,197,253,0.8); margin-bottom:0.4rem; text-align:center;">Plus tard</div>
            <div class="org-postit postit-blue" style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">IA</div>
            <div class="org-postit postit-blue" style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">Trop d'appels</div>
            <div class="org-postit postit-purple" style="font-size:clamp(0.55rem,1.1vw,0.85rem); margin:0.25rem auto;">Automatiser</div>
          </div>
        </div>

        <div class="compare-label right">Après · Cadré</div>
      </div>

      <div class="compare-handle" id="compareHandle"></div>
    </div>

    <p class="text-center mt-5 text-sm" style="color: var(--text-tertiary);">
      Faites glisser le curseur pour comparer avant et après
    </p>

    <div class="max-w-5xl mx-auto mt-3 px-2">
      <input
        type="range" min="0" max="100" value="50"
        id="compareRange"
        class="w-full h-2 rounded-full appearance-none cursor-pointer"
        style="background: linear-gradient(to right, var(--accent) 0%, var(--accent) 50%, var(--bg-tertiary) 50%, var(--bg-tertiary) 100%);"
      />
    </div>

  </div>
</section>

<script>
  const container = document.getElementById('compareContainer') as HTMLElement | null;
  const range = document.getElementById('compareRange') as HTMLInputElement | null;

  if (container) {
    let dragging = false;

    function setPos(pct: number) {
      pct = Math.max(0, Math.min(100, pct));
      container!.style.setProperty('--slider-pos', pct + '%');
      if (range && Number(range.value) !== Math.round(pct)) {
        range.value = String(pct);
        updateRangeBg(pct);
      }
    }

    function updateRangeBg(pct: number) {
      if (!range) return;
      range.style.background = `linear-gradient(to right, var(--accent) 0%, var(--accent) ${pct}%, var(--bg-tertiary) ${pct}%, var(--bg-tertiary) 100%)`;
    }

    function fromClientX(clientX: number) {
      const r = container!.getBoundingClientRect();
      setPos(((clientX - r.left) / r.width) * 100);
    }

    setPos(50);

    container.addEventListener('pointerdown', (e) => {
      container.setPointerCapture(e.pointerId);
      fromClientX(e.clientX);
    });
    container.addEventListener('pointermove', (e) => {
      if (e.buttons > 0) fromClientX(e.clientX);
    });
    if (range) range.addEventListener('input', (e) => setPos(Number((e.target as HTMLInputElement).value)));
  }
</script>
