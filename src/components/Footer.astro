---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="py-12 border-t" style="background: var(--bg-secondary); border-color: var(--border);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex items-center gap-4" style="color: var(--text-primary);">
      <Logo height="24px" />
      <span class="text-sm" style="color: var(--text-tertiary);">© {year} David Gacquer</span>
    </div>
    <div class="flex gap-6 text-sm" style="color: var(--text-tertiary);">
      <a href="https://www.linkedin.com/in/david-gacquer-20973064/" target="_blank" rel="noopener" class="hover:opacity-100 transition">LinkedIn</a>
      <a href="/mentions-legales/" class="hover:opacity-100 transition">Mentions légales</a>
      <a href="/cgv/" class="hover:opacity-100 transition">CGV</a>
    </div>
  </div>
</footer>
