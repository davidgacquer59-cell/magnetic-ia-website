---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="py-12 border-t" style="background: var(--bg-secondary); border-color: var(--border);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex items-center gap-4" style="color: var(--text-primary);">
      <Logo height="24px" />
      <span class="text-sm" style="color: var(--text-tertiary);">© {year} David Gacquer</span>
    </div>
    <div class="flex flex-wrap gap-5 text-sm items-center" style="color: var(--text-tertiary);">
      <a href="/blog" class="hover:opacity-100 transition">Blog</a>
      <a href="https://www.linkedin.com/in/david-gacquer-20973064/" target="_blank" rel="noopener" class="flex items-center gap-1.5 hover:opacity-100 transition">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a href="https://twitter.com/davidgacquer" target="_blank" rel="noopener" class="flex items-center gap-1.5 hover:opacity-100 transition">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Twitter / X
      </a>
      <a href="/mentions-legales/" class="hover:opacity-100 transition">Mentions légales</a>
      <a href="/cgv/" class="hover:opacity-100 transition">CGV</a>
    </div>
  </div>
</footer>
