---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('blog');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const allArticles = await getCollection('blog');
const related = allArticles
  .filter(a => a.slug !== article.slug && a.data.tag === article.data.tag)
  .slice(0, 2);

const articleUrl   = `https://magnetic-ia.fr/blog/${article.slug}`;
const encodedUrl   = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(article.data.title);

const tagIcon: Record<string, string> = {
  'Cas client':     '★',
  'Automatisation': '⚡',
  'Technique':      '⌥',
  'Stratégie':      '◈',
  'Outils':         '◎',
  'IA & PME':       '◆',
};
const icon = tagIcon[article.data.tag] ?? '●';
---

<Layout
  title={`${article.data.title} — Magnetic-IA`}
  description={article.data.excerpt}
  type="article"
>
  <!-- JSON-LD Article — GEO/AIO optimisé -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": article.data.title,
    "description": article.data.excerpt,
    "datePublished": article.data.date,
    "dateModified": article.data.date,
    "url": `https://magnetic-ia.fr/blog/${article.slug}`,
    "author": {
      "@type": "Person",
      "name": "David Gacquer",
      "url": "https://magnetic-ia.fr",
      "jobTitle": "Expert en cadrage de projets IA pour PME",
      "sameAs": [
        "https://www.linkedin.com/in/david-gacquer-20973064/",
        "https://twitter.com/davidgacquer"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Magnetic-IA",
        "url": "https://magnetic-ia.fr"
      }
    },
    "publisher": {
      "@type": "Organization",
      "name": "Magnetic-IA",
      "url": "https://magnetic-ia.fr",
      "logo": {
        "@type": "ImageObject",
        "url": "https://magnetic-ia.fr/favicon.svg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://magnetic-ia.fr/blog/${article.slug}`
    },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".prose p:first-of-type", "h2"]
    },
    "about": {
      "@type": "Thing",
      "name": "Cadrage de projets IA pour PME",
      "description": "Méthode de diagnostic et de priorisation des projets d'intelligence artificielle pour les dirigeants de TPE et PME"
    },
    "keywords": `${article.data.tag}, cadrage IA, intelligence artificielle PME, David Gacquer, Magnetic-IA`,
    "inLanguage": "fr-FR",
    "isAccessibleForFree": true
  })} />
  <Nav />
  <main class="pt-28 pb-20">

    <!-- Unique conteneur — grille texte + sidebar parfaitement alignés -->
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-[minmax(0,640px)_240px] lg:gap-14 items-start">

        <!-- ═══ COLONNE GAUCHE ═══ -->
        <div>

          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-xs mb-8 flex-wrap" style="color: var(--text-tertiary);">
            <a href="/" class="hover:opacity-70 transition">Accueil</a>
            <span>/</span>
            <a href="/blog" class="hover:opacity-70 transition">Blog</a>
            <span>/</span>
            <span class="truncate max-w-[240px]" style="color: var(--text-secondary);">{article.data.title}</span>
          </nav>

          <!-- Tag + meta -->
          <div class="flex items-center gap-3 mb-5 flex-wrap">
            <span
              class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold"
              style={`background: ${article.data.tagColor}18; color: ${article.data.tagColor}; border: 1px solid ${article.data.tagColor}30;`}
            >
              {article.data.tag}
            </span>
            <span class="text-xs" style="color: var(--text-tertiary);">{article.data.date}</span>
            <span class="text-xs" style="color: var(--text-tertiary);">·</span>
            <span class="text-xs" style="color: var(--text-tertiary);">{article.data.readTime} de lecture</span>
          </div>

          <!-- Titre -->
          <h1 class="text-3xl md:text-4xl font-bold tracking-tight leading-tight mb-5">
            {article.data.title}
          </h1>

          <!-- Excerpt -->
          <p class="text-lg leading-relaxed mb-7" style="color: var(--text-secondary);">
            {article.data.excerpt}
          </p>

          <!-- Auteur ligne -->
          <div class="flex items-center gap-4 p-5 rounded-2xl mb-10" style="background: var(--bg-secondary); border: 1px solid var(--border);">
            <div class="w-11 h-11 rounded-full overflow-hidden flex-shrink-0" style="background: var(--bg-tertiary);">
              <img src="/images/david-gacquer.png" alt="David Gacquer" class="w-full h-full object-cover" onerror="this.style.display='none'" />
            </div>
            <div>
              <p class="text-sm font-semibold" style="color: var(--text-primary);">David Gacquer</p>
              <p class="text-xs mt-0.5" style="color: var(--text-tertiary);">Consultant cadrage IA · Magnetic-IA</p>
            </div>
          </div>

          <!-- Visuel header article (pas de photo client) -->
          <div
            class="w-full rounded-2xl mb-10 flex items-center justify-center relative overflow-hidden"
            style={`aspect-ratio: 16/7; background: linear-gradient(135deg, ${article.data.tagColor}12, ${article.data.tagColor}04); border: 1px solid ${article.data.tagColor}20;`}
          >
            <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 28px 28px;"></div>
            <div class="relative text-center">
              <div class="text-6xl mb-2 leading-none" style={`color: ${article.data.tagColor}; opacity: 0.5;`}>{icon}</div>
              <p class="text-xs font-mono uppercase tracking-[0.22em]" style={`color: ${article.data.tagColor}; opacity: 0.4;`}>{article.data.tag}</p>
            </div>
          </div>

          <!-- Contenu Markdown -->
          <div class="prose">
            <Content />
          </div>

          <!-- Partage mobile (caché sur desktop) -->
          <div class="lg:hidden mt-12 p-6 rounded-2xl" style="background: var(--bg-secondary); border: 1px solid var(--border);">
            <p class="text-sm font-semibold mb-4" style="color: var(--text-primary);">Partager cet article</p>
            <div class="flex flex-wrap gap-3">
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer"
                class="px-4 py-2 rounded-xl text-xs font-semibold"
                style="background: #0077b518; color: #0077b5; border: 1px solid #0077b530;">LinkedIn</a>
              <a href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer"
                class="px-4 py-2 rounded-xl text-xs font-semibold"
                style="background: #1da1f218; color: #1da1f2; border: 1px solid #1da1f230;">X / Twitter</a>
              <button onclick="window.print()" class="px-4 py-2 rounded-xl text-xs font-semibold"
                style="background: var(--bg-tertiary); color: var(--text-secondary); border: 1px solid var(--border);">PDF</button>
            </div>
          </div>

          <!-- CTA fin d'article -->
          <div class="mt-12 p-8 rounded-2xl relative overflow-hidden" style="background: var(--bg-secondary); border: 1px solid var(--border);">
            <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl" style="background: linear-gradient(90deg, var(--accent), #a78bfa);"></div>
            <div class="text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-3" style="color: var(--accent);">Envie d'aller plus loin ?</div>
            <h3 class="text-xl font-bold mb-3">Un échange de 30 min pour faire le point</h3>
            <p class="text-sm leading-relaxed mb-6" style="color: var(--text-secondary);">
              Gratuit, sans engagement. On regarde ensemble où vous en êtes et si un cadrage a du sens pour vous.
            </p>
            <a href="https://calendly.com/davidgacquer59/consultation-decouverte?utm_source=blog&utm_medium=article-cta&utm_campaign=30min-offert" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition text-sm">
              Prendre rendez-vous
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          </div>

          <!-- Commentaires -->
          <div class="mt-12">
            <h3 class="text-lg font-bold mb-4" style="color: var(--text-primary);">Commentaires</h3>
            <div class="p-6 rounded-2xl text-center" style="background: var(--bg-secondary); border: 1px solid var(--border);">
              <p class="text-sm mb-2" style="color: var(--text-secondary);">Les commentaires seront activés prochainement.</p>
              <p class="text-xs" style="color: var(--text-tertiary);">
                En attendant, <a href="https://www.linkedin.com/in/david-gacquer-20973064/" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--accent);">réagissez sur LinkedIn</a> ou <a href="/contact" class="underline" style="color: var(--accent);">envoyez-moi un message</a>.
              </p>
            </div>
          </div>

          <!-- Articles liés -->
          {related.length > 0 && (
            <div class="mt-12">
              <h3 class="text-lg font-bold mb-5" style="color: var(--text-primary);">Dans la même catégorie</h3>
              <div class="grid md:grid-cols-2 gap-5">
                {related.map((a) => (
                  <a href={`/blog/${a.slug}`} class="group p-7 rounded-xl card-hover block"
                    style="background: var(--bg-secondary); border: 1px solid var(--border);">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold mb-3"
                      style={`background: ${a.data.tagColor}18; color: ${a.data.tagColor}; border: 1px solid ${a.data.tagColor}30;`}>
                      {a.data.tag}
                    </span>
                    <p class="font-semibold text-base leading-snug mb-2 group-hover:opacity-80 transition" style="color: var(--text-primary);">{a.data.title}</p>
                    <p class="text-xs" style="color: var(--text-tertiary);">{a.data.readTime} de lecture</p>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Retour -->
          <div class="mt-10 pt-8 border-t" style="border-color: var(--border);">
            <a href="/blog" style="color: var(--accent);" class="text-sm hover:opacity-80 transition">← Retour au blog</a>
          </div>

        </div>
        <!-- ═══ FIN COLONNE GAUCHE ═══ -->

        <!-- ═══ SIDEBAR ═══ -->
        <aside class="hidden lg:block mt-14">
          <div class="sticky top-28 space-y-5">

            <div class="p-5 rounded-2xl" style="background: var(--bg-secondary); border: 1px solid var(--border);">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 rounded-full overflow-hidden flex-shrink-0" style="background: var(--bg-tertiary);">
                  <img src="/images/david-gacquer.png" alt="David Gacquer" class="w-full h-full object-cover" onerror="this.style.display='none'" />
                </div>
                <div>
                  <p class="text-sm font-semibold" style="color: var(--text-primary);">David Gacquer</p>
                  <p class="text-xs" style="color: var(--text-tertiary);">Magnetic-IA · Hauts-de-France</p>
                </div>
              </div>
              <p class="text-xs leading-relaxed" style="color: var(--text-secondary);">
                Consultant cadrage de projets IA pour dirigeants de TPE/PME.
              </p>
            </div>

            <div class="p-5 rounded-2xl" style="background: rgba(96,165,250,0.06); border: 1px solid rgba(96,165,250,0.2);">
              <p class="text-sm font-bold mb-1.5" style="color: var(--text-primary);">Un projet IA en tête ?</p>
              <p class="text-xs leading-relaxed mb-4" style="color: var(--text-secondary);">30 min offertes pour faire le point.</p>
              <a href="https://calendly.com/davidgacquer59/consultation-decouverte?utm_source=blog&utm_medium=sidebar&utm_campaign=30min-offert" target="_blank" rel="noopener noreferrer"
                class="block text-center px-4 py-2.5 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition text-xs">
                Réserver →
              </a>
            </div>

            <div class="p-5 rounded-2xl" style="background: var(--bg-secondary); border: 1px solid var(--border);">
              <p class="text-xs font-mono uppercase tracking-[0.15em] mb-3" style="color: var(--text-tertiary);">Catégorie</p>
              <a href="/blog" class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-semibold"
                style={`background: ${article.data.tagColor}18; color: ${article.data.tagColor}; border: 1px solid ${article.data.tagColor}30;`}>
                {article.data.tag}
              </a>
            </div>

            <div class="p-5 rounded-2xl" style="background: var(--bg-secondary); border: 1px solid var(--border);">
              <p class="text-xs font-mono uppercase tracking-[0.15em] mb-3" style="color: var(--text-tertiary);">Partager</p>
              <div class="flex flex-col gap-2">
                <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer"
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-medium hover:opacity-80 transition"
                  style="background: #0077b518; color: #0077b5; border: 1px solid #0077b530;">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                </a>
                <a href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer"
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-medium hover:opacity-80 transition"
                  style="background: #1da1f218; color: #1da1f2; border: 1px solid #1da1f230;">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  X (Twitter)
                </a>
                <button id="copyLink"
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-medium hover:opacity-80 transition w-full text-left"
                  style="background: var(--bg-tertiary); color: var(--text-secondary); border: 1px solid var(--border);">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                  <span id="copyLinkLabel">Copier le lien</span>
                </button>
                <button onclick="window.print()"
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-medium hover:opacity-80 transition w-full text-left"
                  style="background: var(--bg-tertiary); color: var(--text-secondary); border: 1px solid var(--border);">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                  PDF / Imprimer
                </button>
              </div>
            </div>

          </div>
        </aside>
        <!-- ═══ FIN SIDEBAR ═══ -->

      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .prose {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.85;
  }
  .prose :global(h2) {
    position: relative;
    font-size: 1.5rem;
    font-weight: 700;
    color: #93c5fd;
    margin: 3.5rem 0 1rem;
    padding-left: 1.1rem;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .prose :global(h2)::before {
    content: '';
    position: absolute;
    left: 0; top: 0.15em; bottom: 0.15em;
    width: 3px;
    background: var(--accent);
    border-radius: 2px;
  }
  .prose :global(h3) {
    font-size: 1.08rem;
    font-weight: 700;
    color: #6ee7b7;
    margin: 2rem 0 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .prose :global(h3)::before {
    content: '';
    display: inline-block;
    width: 14px; height: 2px;
    background: #6ee7b7;
    flex-shrink: 0;
    opacity: 0.55;
    border-radius: 1px;
  }
  .prose :global(p) { margin: 0 0 1.4rem; }
  .prose :global(h2 + p) { color: var(--text-primary); }
  .prose :global(strong) { color: var(--text-primary); font-weight: 600; }

  .prose :global(ul) { margin: 0 0 1.4rem; padding: 0; list-style: none; }
  .prose :global(ul li) { position: relative; padding-left: 1.3rem; margin-bottom: 0.5rem; }
  .prose :global(ul li)::before {
    content: ''; position: absolute; left: 0; top: 0.65em;
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--accent); opacity: 0.7;
  }
  .prose :global(ol) { margin: 0 0 1.4rem; padding: 0; list-style: none; counter-reset: ol-counter; }
  .prose :global(ol li) { position: relative; padding-left: 2rem; margin-bottom: 0.5rem; counter-increment: ol-counter; }
  .prose :global(ol li)::before {
    content: counter(ol-counter);
    position: absolute; left: 0; top: 0.05em;
    width: 1.3rem; height: 1.3rem; border-radius: 50%;
    background: rgba(96,165,250,0.12); color: var(--accent);
    font-size: 0.7rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace;
  }

  .prose :global(blockquote) {
    position: relative;
    margin: 2.5rem 0;
    padding: 1.5rem 1.5rem 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(96,165,250,0.07), rgba(96,165,250,0.02));
    border-radius: 1rem;
    border: 1px solid rgba(96,165,250,0.2);
  }
  .prose :global(blockquote)::before {
    content: '"'; position: absolute; top: -0.5rem; left: 1rem;
    font-family: 'Instrument Serif', serif; font-size: 4rem; line-height: 1;
    color: var(--accent); opacity: 0.3;
  }
  .prose :global(blockquote p) { margin: 0; font-style: italic; color: var(--text-primary); line-height: 1.7; }
  .prose :global(blockquote p + p) { margin-top: 0.6rem; font-size: 0.88rem; font-style: normal; color: var(--accent); font-weight: 600; }

  .prose :global(table) {
    width: 100%; border-collapse: separate; border-spacing: 0;
    margin: 2rem 0; font-size: 0.9rem;
    border-radius: 0.75rem; overflow: hidden; border: 1px solid var(--border);
  }
  .prose :global(th) {
    background: var(--bg-tertiary); color: var(--text-primary);
    font-weight: 600; padding: 0.7rem 1rem;
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border);
  }
  .prose :global(td) { padding: 0.7rem 1rem; border-bottom: 1px solid var(--border); color: var(--text-secondary); }
  .prose :global(tr:last-child td) { border-bottom: none; }
  .prose :global(tr:nth-child(even) td) { background: rgba(255,255,255,0.015); }

  .prose :global(code) {
    background: var(--bg-tertiary); color: var(--accent);
    padding: 0.12em 0.4em; border-radius: 4px;
    font-size: 0.87em; font-family: 'JetBrains Mono', monospace;
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration-line: underline;
    text-decoration-color: rgba(96,165,250,0.3);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }
  .prose :global(a:hover) { text-decoration-color: var(--accent); }
  .prose :global(hr) { border: none; border-top: 1px solid var(--border); margin: 3rem 0; }

  @media print {
    aside, nav, footer, .lg\\:hidden { display: none !important; }
    .prose { color: #000; font-size: 12pt; }
    .prose :global(h2) { color: #1e3a5f; }
    .prose :global(h3) { color: #1e6e50; }
  }
</style>

<script define:vars={{ articleUrl }}>
  const btn   = document.getElementById('copyLink');
  const label = document.getElementById('copyLinkLabel');
  if (btn && label) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(articleUrl);
        label.textContent = '✓ Lien copié !';
        setTimeout(() => { label.textContent = 'Copier le lien'; }, 2000);
      } catch { label.textContent = 'Erreur'; }
    });
  }
</script>
