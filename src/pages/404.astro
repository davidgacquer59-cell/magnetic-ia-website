---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page introuvable — Magnetic-IA"
  description="Cette page n'existe pas. Retournez à l'accueil pour découvrir les offres de cadrage de projets IA pour PME."
>
  <Nav />
  <main class="pt-28 pb-20 min-h-screen flex items-center">
    <div class="max-w-2xl mx-auto px-6 lg:px-8 text-center">

      <!-- Numéro 404 -->
      <div class="relative mb-8">
        <span
          class="font-serif italic select-none"
          style="font-size: clamp(8rem, 20vw, 14rem); line-height: 1; color: rgba(96,165,250,0.08); display: block;"
        >
          404
        </span>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center">
            <div class="text-4xl mb-2">🗂️</div>
            <p class="text-sm font-mono font-semibold uppercase tracking-[0.2em]" style="color: var(--accent);">Page introuvable</p>
          </div>
        </div>
      </div>

      <!-- Message -->
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
        Cette page n'existe pas.
        <span class="font-serif italic" style="color: var(--accent);"> Ou plus.</span>
      </h1>

      <p class="text-base leading-relaxed mb-10" style="color: var(--text-secondary);">
        Peut-être que l'URL a changé, ou que le lien était cassé. Pas de panique — l'essentiel est accessible depuis l'accueil.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-7 py-4 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition shadow-xl text-base"
        >
          ← Retour à l'accueil
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-7 py-4 font-medium rounded-xl transition text-base"
          style="border: 1px solid var(--border); color: var(--text-primary);"
        >
          Voir le blog
        </a>
      </div>

      <!-- Liens rapides -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[
          { label: 'Méthode', href: '/#methode' },
          { label: 'Offres', href: '/#services' },
          { label: 'Diagnostic', href: '/#diagnostic' },
          { label: 'Contact', href: '/contact' },
        ].map(link => (
          <a
            href={link.href}
            class="px-4 py-3 rounded-xl text-sm font-medium text-center transition hover:opacity-80"
            style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-secondary);"
          >
            {link.label}
          </a>
        ))}
      </div>

    </div>
  </main>
  <Footer />
</Layout>
