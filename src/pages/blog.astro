---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('blog');
const articles = allArticles.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const tags = ['Tous', ...new Set(articles.map(a => a.data.tag))];
---

<Layout
  title="Blog — Magnetic-IA"
  description="Articles sur le cadrage de projets IA, l'automatisation, les outils no-code et la stratégie digitale pour dirigeants de PME."
>
  <Nav />
  <main class="pt-28 pb-20">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">

      <Breadcrumb items={[
        { label: 'Accueil', href: '/' },
        { label: 'Blog' },
      ]} />

      <!-- Header -->
      <div class="mb-12">
        <div class="text-sm font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--accent);">Blog</div>
        <h1 class="text-2xl md:text-4xl font-bold tracking-tight mb-6">
          Ressources & réflexions
        </h1>
        <p class="text-lg max-w-2xl" style="color: var(--text-secondary);">
          Cas clients, outils, méthodes et analyses. Du concret pour les dirigeants qui veulent comprendre et agir, pas juste lire.
        </p>
      </div>

      <!-- Filtres tags -->
      <div class="flex flex-wrap gap-2 mb-10" id="tagFilters">
        {tags.map((tag) => (
          <button
            class="tag-btn px-4 py-1.5 rounded-full text-xs font-semibold transition"
            data-tag={tag}
          >
            {tag}
          </button>
        ))}
      </div>

      <!-- Grille articles -->
      <div class="grid md:grid-cols-2 gap-8" id="articlesGrid">
        {articles.map((article) => (
          <article
            class="group article-card rounded-2xl overflow-hidden card-hover"
            data-tag={article.data.tag}
            style="background: var(--bg-secondary); border: 1px solid var(--border);"
          >
            <!-- Image / header coloré -->
            {article.data.image ? (
              <div class="aspect-video overflow-hidden">
                <img
                  src={article.data.image}
                  alt={article.data.imageAlt || article.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                />
              </div>
            ) : (
              <div
                class="aspect-video flex items-center justify-center relative overflow-hidden"
                style={`background: linear-gradient(135deg, ${article.data.tagColor}18, ${article.data.tagColor}08);`}
              >
                <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 24px 24px;"></div>
                <span
                  class="text-4xl font-bold font-serif italic relative"
                  style={`color: ${article.data.tagColor}40;`}
                >
                  {article.data.tag}
                </span>
              </div>
            )}

            <div class="p-7">
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                  <span
                    class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold"
                    style={`background: ${article.data.tagColor}18; color: ${article.data.tagColor}; border: 1px solid ${article.data.tagColor}30;`}
                  >
                    {article.data.tag}
                  </span>
                  <span
                    class="new-badge hidden inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold"
                    data-article-date={article.data.date}
                    style="background: rgba(255,93,143,0.15); color: #ff5d8f; border: 1px solid rgba(255,93,143,0.35); letter-spacing: 0.05em;"
                  >
                    Nouveau
                  </span>
                </div>
                <span class="text-xs" style="color: var(--text-tertiary);">{article.data.readTime} de lecture</span>
              </div>

              <h2 class="font-bold text-lg leading-snug mb-3 group-hover:opacity-80 transition" style="color: var(--text-primary);">
                {article.data.title}
              </h2>

              <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
                {article.data.excerpt}
              </p>

              <div class="flex items-center justify-between">
                <span class="text-xs" style="color: var(--text-tertiary);">{article.data.date}</span>
                <a
                  href={`/blog/${article.slug}`}
                  class="inline-flex items-center gap-1 text-xs font-semibold transition hover:gap-2"
                  style={`color: ${article.data.tagColor};`}
                >
                  Lire l'article
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Message aucun résultat -->
      <p id="noResults" class="hidden text-center py-16 text-lg" style="color: var(--text-tertiary);">
        Aucun article dans cette catégorie pour l'instant.
      </p>

      <div class="mt-16 pt-8 border-t" style="border-color: var(--border);">
        <a href="/" style="color: var(--accent);" class="text-sm hover:opacity-80 transition">← Retour à l'accueil</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .tag-btn {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-secondary);
  }
  .tag-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .tag-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }
  .article-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .article-card.hidden-card {
    display: none;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards   = document.querySelectorAll<HTMLElement>('.article-card');
  const noResults = document.getElementById('noResults');

  function filterByTag(tag: string) {
    let visible = 0;
    cards.forEach((card) => {
      const cardTag = card.dataset.tag ?? '';
      const show = tag === 'Tous' || cardTag === tag;
      card.classList.toggle('hidden-card', !show);
      if (show) visible++;
    });
    if (noResults) noResults.classList.toggle('hidden', visible > 0);
    buttons.forEach((btn) => btn.classList.toggle('active', btn.dataset.tag === tag));
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => filterByTag(btn.dataset.tag ?? 'Tous'));
  });

  // Activer "Tous" par défaut
  filterByTag('Tous');

  // Badge "Nouveau" : visible pendant 7 jours après la date de l'article
  const NEW_DAYS = 7;
  const now = Date.now();
  document.querySelectorAll<HTMLElement>('.new-badge').forEach((badge) => {
    const date = badge.dataset.articleDate;
    if (!date) return;
    const age = (now - new Date(date).getTime()) / (1000 * 60 * 60 * 24);
    if (age <= NEW_DAYS) badge.classList.remove('hidden');
  });
</script>
