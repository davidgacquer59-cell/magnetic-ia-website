---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const CALENDLY_URL = 'https://calendly.com/davidgacquer59/consultation-decouverte?utm_source=site&utm_medium=contact-page&utm_campaign=30min-offert';
---

<Layout
  title="Contact — David Gacquer, cadrage de projets IA pour PME — Magnetic-IA"
  description="Prenez 30 minutes avec David Gacquer pour faire le point sur votre projet IA. Diagnostic gratuit, sans engagement. Basé à Wambrechies, intervient dans toute la France."
>
  <Nav />
  <main class="pt-28 pb-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">

      <!-- Header -->
      <div class="max-w-2xl mb-16">
        <div class="text-sm font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--accent);">Contact</div>
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6 leading-tight">
          Parlons de votre<br />
          <span class="font-serif italic" style="color: var(--text-tertiary);">projet IA.</span>
        </h1>
        <p class="text-lg leading-relaxed" style="color: var(--text-secondary);">
          Un premier échange de 30 minutes, gratuit, pour comprendre votre situation et voir si je peux vous aider.
        </p>
      </div>

      <div class="grid lg:grid-cols-[1fr_380px] gap-12">

        <!-- Calendly embed -->
        <div>
          <div class="text-sm font-semibold uppercase tracking-[0.15em] mb-6" style="color: var(--text-tertiary);">Choisissez un créneau</div>
          <div
            class="calendly-inline-widget rounded-2xl overflow-hidden"
            data-url={`${CALENDLY_URL}?hide_event_type_details=1&hide_gdpr_banner=1&background_color=0f1424&text_color=f1f5f9&primary_color=3b82f6`}
            style="min-width: 320px; height: 700px; border: 1px solid var(--border); overflow: hidden;"
          ></div>
          <script async src="https://assets.calendly.com/assets/external/widget.js"></script>
        </div>

        <!-- Infos de contact -->
        <div class="space-y-8">
          <div>
            <div class="text-sm font-semibold uppercase tracking-[0.15em] mb-6" style="color: var(--text-tertiary);">Ou contactez-moi directement</div>

            <div class="space-y-4">
              <a href="mailto:contact@magnetic-ia.fr" class="flex items-center gap-4 p-4 rounded-2xl transition card-hover" style="background: var(--bg-secondary); border: 1px solid var(--border);">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(59,130,246,0.1); color: var(--accent);">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-medium mb-0.5" style="color: var(--text-tertiary);">Email</div>
                  <div class="font-semibold text-sm" style="color: var(--text-primary);">contact@magnetic-ia.fr</div>
                </div>
              </a>

              <a href="tel:+33632351294" class="flex items-center gap-4 p-4 rounded-2xl transition card-hover" style="background: var(--bg-secondary); border: 1px solid var(--border);">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(59,130,246,0.1); color: var(--accent);">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-medium mb-0.5" style="color: var(--text-tertiary);">Téléphone / WhatsApp</div>
                  <div class="font-semibold text-sm" style="color: var(--text-primary);">+33 6 32 35 12 94</div>
                </div>
              </a>

              <a href="https://www.linkedin.com/in/david-gacquer-20973064/" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 rounded-2xl transition card-hover" style="background: var(--bg-secondary); border: 1px solid var(--border);">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(59,130,246,0.1); color: var(--accent);">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-medium mb-0.5" style="color: var(--text-tertiary);">LinkedIn</div>
                  <div class="font-semibold text-sm" style="color: var(--text-primary);">david-gacquer-20973064</div>
                </div>
              </a>
            </div>
          </div>

          <!-- Localisation -->
          <div class="p-6 rounded-2xl" style="background: var(--bg-secondary); border: 1px solid var(--border);">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--accent);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <div class="font-semibold text-sm mb-1" style="color: var(--text-primary);">Wambrechies (59), Hauts-de-France</div>
                <div class="text-sm" style="color: var(--text-secondary);">Interventions en présentiel sur la métropole lilloise et à distance partout en France.</div>
              </div>
            </div>
          </div>

          <!-- Délai de réponse -->
          <div class="p-4 rounded-2xl flex items-center gap-3" style="background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2);">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #34d399;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm" style="color: #34d399;">Réponse sous 24h garantie</span>
          </div>
        </div>
      </div>

      <div class="mt-16 pt-8 border-t" style="border-color: var(--border);">
        <a href="/" style="color: var(--accent);" class="text-sm hover:opacity-80 transition">← Retour à l'accueil</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
