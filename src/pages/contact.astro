---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout
  title="Contact — Diagnostic IA gratuit pour dirigeants de PME | Magnetic-IA"
  description="Prenez 30 minutes avec David Gacquer pour un diagnostic IA gratuit, sans engagement — Hauts-de-France."
>
  <Nav />
  <main class="pt-28 pb-20 flex-1">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">

      <Breadcrumb items={[
        { label: 'Accueil', href: '/' },
        { label: 'Contact' },
      ]} />

      <!-- Header -->
      <div class="mb-12">
        <div class="inline-flex items-center gap-3 mb-6">
          <span class="w-6 h-px" style="background: var(--accent);"></span>
          <span class="text-xs font-mono font-semibold uppercase tracking-[0.22em]" style="color: var(--accent);">Contact</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
          Parlons de votre
          <span class="font-serif italic" style="color: var(--accent);"> projet IA.</span>
        </h1>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          Choisissez le mode de contact qui vous convient. Réponse garantie sous 24h.
        </p>
      </div>

      <!-- Options de contact -->
      <div class="flex flex-col gap-4">

        <!-- Calendly -->
        <a
          href="https://calendly.com/davidgacquer59/consultation-decouverte?utm_source=site&utm_medium=contact-page&utm_campaign=30min-offert"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between w-full p-6 rounded-2xl transition hover:opacity-90"
          style="background: rgba(96,165,250,0.08); border: 2px solid rgba(96,165,250,0.3);"
        >
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(96,165,250,0.15);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--accent);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="font-semibold" style="color: var(--text-primary);">Réserver un créneau de 30 min</p>
              <p class="text-sm" style="color: var(--text-secondary);">Gratuit · Sans engagement · Réponse immédiate</p>
            </div>
          </div>
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--accent);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>

        <!-- WhatsApp -->
        <a
          href="https://wa.me/33632351294"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between w-full p-6 rounded-2xl transition hover:opacity-90"
          style="background: var(--bg-secondary); border: 1px solid var(--border);"
        >
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(37,211,102,0.12);">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" style="color: #25d366;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div>
              <p class="font-semibold" style="color: var(--text-primary);">WhatsApp</p>
              <p class="text-sm" style="color: var(--text-secondary);">+33 6 32 35 12 94 · Réponse rapide</p>
            </div>
          </div>
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--text-tertiary);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/david-gacquer-20973064/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between w-full p-6 rounded-2xl transition hover:opacity-90"
          style="background: var(--bg-secondary); border: 1px solid var(--border);"
        >
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(10,102,194,0.12);">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" style="color: #0a66c2;"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <div>
              <p class="font-semibold" style="color: var(--text-primary);">LinkedIn</p>
              <p class="text-sm" style="color: var(--text-secondary);">Message direct via LinkedIn</p>
            </div>
          </div>
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--text-tertiary);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>

      </div>

      <!-- Note bas -->
      <p class="text-xs text-center mt-8" style="color: var(--text-tertiary);">
        Réponse garantie sous 24h · Basé à Wambrechies, Hauts-de-France
      </p>

    </div>
  </main>
  <Footer />
</Layout>
