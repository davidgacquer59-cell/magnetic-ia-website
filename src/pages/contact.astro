---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const merci = Astro.url.searchParams.get('merci') === '1';
---

<Layout
  title="Contact — David Gacquer, cadrage de projets IA pour PME — Magnetic-IA"
  description="Prenez 30 minutes avec David Gacquer pour faire le point sur votre projet IA. Diagnostic gratuit, sans engagement."
>
  <Nav />
  <main class="pt-28 pb-20">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">

      <!-- Header -->
      <div class="mb-12">
        <div class="inline-flex items-center gap-3 mb-6">
          <span class="w-6 h-px" style="background: var(--accent);"></span>
          <span class="text-xs font-mono font-semibold uppercase tracking-[0.22em]" style="color: var(--accent);">Contact</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
          Parlons de votre
          <span class="font-serif italic" style="color: var(--accent);"> projet IA.</span>
        </h1>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          Remplissez ce formulaire ou réservez directement un créneau de 30 minutes. Réponse garantie sous 24h.
        </p>
      </div>

      <!-- Bouton Calendly -->
      <a
        href="https://calendly.com/davidgacquer59/consultation-decouverte?utm_source=site&utm_medium=contact-page&utm_campaign=30min-offert"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-between w-full p-5 rounded-2xl mb-10 transition hover:opacity-90"
        style="background: rgba(96,165,250,0.08); border: 1px solid rgba(96,165,250,0.25);"
      >
        <div>
          <p class="font-semibold text-sm mb-0.5" style="color: var(--text-primary);">Réserver un créneau gratuit de 30 min</p>
          <p class="text-xs" style="color: var(--text-secondary);">Calendly · Sans engagement · Réponse immédiate</p>
        </div>
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--accent);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>

      <!-- Séparateur -->
      <div class="flex items-center gap-4 mb-8">
        <div class="flex-1 h-px" style="background: var(--border);"></div>
        <span class="text-xs font-mono uppercase tracking-[0.15em]" style="color: var(--text-tertiary);">ou envoyez un message</span>
        <div class="flex-1 h-px" style="background: var(--border);"></div>
      </div>

      <!-- Formulaire -->
      <div id="form-wrap" class={merci ? 'hidden' : ''}>
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5">

          <div class="grid md:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium mb-2" style="color: var(--text-primary);">Prénom & Nom *</label>
              <input
                type="text" name="name" required
                placeholder="Marie Dupont"
                class="w-full px-4 py-3 rounded-xl text-sm transition"
                style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-primary); outline: none;"
              />
            </div>
            <div>
              <label class="block text-sm font-medium mb-2" style="color: var(--text-primary);">Entreprise</label>
              <input
                type="text" name="company"
                placeholder="Mon Entreprise SAS"
                class="w-full px-4 py-3 rounded-xl text-sm transition"
                style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-primary); outline: none;"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--text-primary);">Email *</label>
            <input
              type="email" name="email" required
              placeholder="marie@monentreprise.fr"
              class="w-full px-4 py-3 rounded-xl text-sm transition"
              style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-primary); outline: none;"
            />
          </div>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--text-primary);">Votre besoin *</label>
            <select
              name="subject" required
              class="w-full px-4 py-3 rounded-xl text-sm transition"
              style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-secondary); outline: none; appearance: none; cursor: pointer;"
            >
              <option value="" disabled selected>Sélectionnez votre besoin</option>
              <option value="Audit Flash (900€)">Audit Flash — demi-journée de diagnostic (900€)</option>
              <option value="Mission Complète (4 500€+)">Mission Complète — cadrage IA (à partir de 4 500€)</option>
              <option value="Formation équipe IA">Formation équipe IA</option>
              <option value="Accompagnement projet">Accompagnement projet sur mesure</option>
              <option value="Information générale">Demande d'information générale</option>
              <option value="Partenariat">Proposition de partenariat</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--text-primary);">Votre message *</label>
            <textarea
              name="message" required rows="5"
              placeholder="Décrivez votre situation, vos enjeux actuels, ce que vous cherchez à résoudre..."
              class="w-full px-4 py-3 rounded-xl text-sm transition resize-none"
              style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-primary); outline: none;"
            ></textarea>
          </div>

          <!-- Web3Forms access key — remplacer YOUR_ACCESS_KEY par la clé reçue sur web3forms.com -->
          <input type="hidden" name="access_key" value="41b886dc-bc26-4259-8629-f7430109ec69" />
          <input type="hidden" name="redirect" value="https://magnetic-ia.fr/contact?merci=1" />
          <input type="hidden" name="from_name" value="Site magnetic-ia.fr" />
          <input type="checkbox" name="botcheck" style="display:none" />

          <button
            type="submit"
            class="w-full py-4 px-8 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition text-base"
          >
            Envoyer mon message →
          </button>
          <p class="text-xs text-center" style="color: var(--text-tertiary);">
            Réponse garantie sous 24h · Vos données restent confidentielles
          </p>

        </form>
      </div>

      <!-- Message de confirmation -->
      <div id="form-success" class={`${merci ? '' : 'hidden'} text-center py-12`}>
        <div class="text-4xl mb-4">✓</div>
        <h2 class="text-2xl font-bold mb-3" style="color: var(--text-primary);">Message envoyé !</h2>
        <p class="text-base leading-relaxed mb-6" style="color: var(--text-secondary);">
          Merci pour votre message. Je reviens vers vous sous 24h pour faire le point ensemble.
        </p>
        <a href="/" class="inline-flex items-center gap-2 text-sm font-medium" style="color: var(--accent);">
          ← Retour à l'accueil
        </a>
      </div>

      <!-- Autres moyens de contact -->
      <div class="mt-10 pt-8 border-t flex flex-wrap gap-4 justify-center" style="border-color: var(--border);">
        <a href="https://www.linkedin.com/in/david-gacquer-20973064/" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm transition hover:opacity-80"
          style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-secondary);">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href="https://wa.me/33632351294" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm transition hover:opacity-80"
          style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-secondary);">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  input:focus, textarea:focus, select:focus {
    border-color: var(--accent) !important;
    box-shadow: 0 0 0 3px rgba(96,165,250,0.15);
  }
  select option { background: var(--bg-secondary); color: var(--text-primary); }
  #form-success .text-4xl {
    width: 64px; height: 64px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(52,211,153,0.15);
    border: 1px solid rgba(52,211,153,0.3);
    border-radius: 50%;
    font-size: 1.5rem;
    color: #34d399;
    margin: 0 auto 1rem;
  }
</style>

