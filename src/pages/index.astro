---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main class="relative">
    <Hero />
    <!-- TODO: BeforeAfter, Audience, Outcomes, Steps, Manifesto, Showcases, IASection, FinalCTA -->
    <section class="py-32 max-w-[var(--container-default)] mx-auto px-7">
      <p class="text-center text-[var(--color-ink-mute)] font-mono-tag text-xs tracking-[0.2em] uppercase">
        Sections en cours de portage · Nav · Hero · Footer livrés
      </p>
    </section>
  </main>
  <Footer />
</Layout>
