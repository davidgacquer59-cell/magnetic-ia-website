---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="relative min-h-screen bg-glow">
    <div class="relative z-10 max-w-[1240px] mx-auto px-6 lg:px-8 pt-32 pb-20">
      <div class="inline-flex items-center gap-2 font-mono-tag text-xs uppercase tracking-[0.18em] text-[var(--color-ink-mute)] mb-6">
        <span class="w-5 h-px bg-[var(--color-accent)]"></span>
        Magnetic-IA · Setup en cours
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.02] tracking-tight">
        Votre digital part dans tous les sens ?
        <br />
        <span class="serif-it text-[var(--color-accent)]">On remet de la clarté.</span>
      </h1>

      <p class="mt-8 text-xl text-[var(--color-ink-dim)] max-w-2xl">
        Site en construction. La home complète sera déployée prochainement avec
        l'ensemble des sections : méthode de cadrage, cas clients, manifeste, philosophie Omotenashi.
      </p>

      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 pt-10 border-t border-[var(--color-line)]">
        <div>
          <div class="text-4xl font-bold">25 ans</div>
          <div class="mt-1 text-sm text-[var(--color-ink-mute)]">Marketing, digital, e-commerce</div>
        </div>
        <div>
          <div class="text-4xl font-bold">+65 %</div>
          <div class="mt-1 text-sm text-[var(--color-ink-mute)]">Trafic qualifié — cas Alfaprint</div>
        </div>
        <div>
          <div class="text-4xl font-bold">+30 %</div>
          <div class="mt-1 text-sm text-[var(--color-ink-mute)]">Taux de conversion</div>
        </div>
        <div>
          <div class="text-4xl font-bold">+50 %</div>
          <div class="mt-1 text-sm text-[var(--color-ink-mute)]">Engagement LinkedIn — cas SwissLife</div>
        </div>
      </div>
    </div>
  </main>
</Layout>
